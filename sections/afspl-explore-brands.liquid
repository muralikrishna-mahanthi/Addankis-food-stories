{%- style -%}
  .brands-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .brands-container-{{ section.id }} {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .brands-header-{{ section.id }} {
    margin-bottom: 40px;
    text-align: center;
  }

  .brands-heading-{{ section.id }} {
    margin: 0;
    font-size: 32px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
  }

  .brands-grid-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ section.settings.gap }}px;
  }

  .brand-item-{{ section.id }} {
    position: relative;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    flex-basis: calc(100% - {{ section.settings.gap }}px);
    transition: transform 0.3s ease;
  }

  @media screen and (min-width: 750px) {
    .brand-item-{{ section.id }} {
      flex-basis: calc(50% - {{ section.settings.gap }}px);
    }
  }

  /* Per-block width overrides on desktop */
  {%- for block in section.blocks -%}
    @media screen and (min-width: 990px) {
      .brand-item--{{ block.id }} {
        flex-basis: calc({{ block.settings.width_desktop }}% - {{ section.settings.gap }}px);
      }
    }
  {%- endfor -%}

  .brand-link-{{ section.id }} {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    position: relative;
    aspect-ratio: {{ section.settings.aspect_ratio }};
  }

  .brand-item-{{ section.id }}:hover {
    transform: scale(1.02);
  }

  .brand-item-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .brand-overlay-{{ section.id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: linear-gradient(transparent, {{ section.settings.overlay_color | color_modify: 'alpha', section.settings.overlay_opacity }});
    display: flex;
    align-items: flex-end;
    padding: 20px;
    transition: height 0.3s ease;
  }

  .brand-item-{{ section.id }}:hover .brand-overlay-{{ section.id }} {
    height: 60%;
  }

  .brand-title-{{ section.id }} {
    margin: 0;
    color: {{ section.settings.text_color }};
    font-size: 20px;
    font-weight: 600;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }
{%- endstyle -%}

<div class="brands-section-{{ section.id }}">
  <div class="brands-container-{{ section.id }}">
    {%- if section.settings.section_title != blank -%}
      <div class="brands-header-{{ section.id }}">
        <h2 class="brands-heading-{{ section.id }}">{{ section.settings.section_title }}</h2>
      </div>
    {%- endif -%}

    <div class="brands-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="brand-item-{{ section.id }} brand-item--{{ block.id }}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="brand-link-{{ section.id }}">
          {%- else -%}
            <div class="brand-link-{{ section.id }}">
          {%- endif -%}
            
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}

            <div class="brand-overlay-{{ section.id }}">
              <h3 class="brand-title-{{ section.id }}">{{ block.settings.heading }}</h3>
            </div>

          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Explore Brands",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Heading",
      "default": "Explore Collaborated Brands"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Gap between items",
      "default": 20
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Image Border Radius",
      "default": 16
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "3/4", "label": "Portrait (3:4)" },
        { "value": "4/3", "label": "Landscape (4:3)" },
        { "value": "16/9", "label": "Wide (16:9)" }
      ],
      "default": "3/4"
    },
    {
      "type": "header",
      "content": "Overlay Settings"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay Opacity",
      "default": 0.6
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Brand Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Brand Name",
          "default": "Brand Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Brand Link"
        },
        {
          "type": "select",
          "id": "width_desktop",
          "label": "Width (Desktop)",
          "options": [
            { "value": "25", "label": "25%" },
            { "value": "33.33", "label": "33%" },
            { "value": "50", "label": "50%" },
            { "value": "66.66", "label": "66%" },
            { "value": "75", "label": "75%" },
            { "value": "100", "label": "100%" }
          ],
          "default": "33.33"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Explore Collaborated Brands",
      "blocks": [
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" }
      ]
    }
  ]
}
{% endschema %}
