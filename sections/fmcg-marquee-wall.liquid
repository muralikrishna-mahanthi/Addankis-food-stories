{%- style -%}
  {%- if section.settings.font_family != blank -%}
    {{ section.settings.font_family | font_face: display: 'swap' }}
  {%- endif -%}

  .fmcg-marquee-wall-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color }};
    --fs-desktop: {{ section.settings.fs_desktop }}rem;
    --fs-mobile: {{ section.settings.fs_mobile }}rem;
    --font-weight: {{ section.settings.fw }};
    --letter-spacing: {{ section.settings.ls }}px;
    --row-gap: {{ section.settings.row_gap | default: 20 }}px;
    --section-min-height: {{ section.settings.section_height | default: '100vh' }};

    background-color: var(--bg-color);
    width: 100%;
    min-height: var(--section-min-height);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    padding: 6rem 0;
    position: relative;
    user-select: none;
    {% if section.settings.font_family != blank %}
      font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
    {% endif %}
  }

  .fmcg-marquee-wall__row {
    white-space: nowrap;
    display: flex;
    align-items: center;
    line-height: 1;
    margin-bottom: var(--row-gap);
    will-change: transform;
    text-transform: {{ section.settings.text_transform }};
    pointer-events: none;
    width: fit-content;
    backface-visibility: hidden;
    transform-style: preserve-3d;
  }

  .fmcg-marquee-wall__row:last-child { margin-bottom: 0; }

  .fmcg-marquee-wall__item {
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
  }

  .fmcg-marquee-wall__text {
    font-size: var(--fs-mobile);
    font-weight: var(--font-weight);
    letter-spacing: var(--letter-spacing);
  }

  @media screen and (min-width: 750px) {
    .fmcg-marquee-wall__text {
      font-size: var(--fs-desktop);
    }
  }

  .fmcg-marquee-wall__logo,
  .fmcg-marquee-wall__svg {
    height: 1.1em;
    width: auto;
    margin: 0 1.2rem;
    object-fit: contain;
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
  }

  .fmcg-marquee-wall__svg svg {
    height: 1.1em;
    width: auto;
    display: block;
  }

  /* Outline Style */
  .fmcg-marquee-wall--outline .fmcg-marquee-wall__text {
    -webkit-text-stroke: 1.5px currentColor;
    color: transparent !important;
  }
  .fmcg-marquee-wall--outline .fmcg-marquee-wall__logo {
    filter: drop-shadow(0 0 1px currentColor);
  }

{%- endstyle -%}

<div class="fmcg-marquee-wall-{{ section.id }} {% if section.settings.use_outline %}fmcg-marquee-wall--outline{% endif %}" id="FmcgMarqueeWall-{{ section.id }}">
  
  {%- for i in (1..4) -%}
    {%- capture row_dir_key -%}dir_{{ i }}{%- endcapture -%}
    {%- capture row_logo_key -%}logo_{{ i }}{%- endcapture -%}
    {%- assign row_logo = section.settings[row_logo_key] -%}
    
    <div class="fmcg-marquee-wall__row fmcg-marquee-wall__row-{{ i }}" 
         data-direction="{{ section.settings[row_dir_key] }}"
         id="Row-{{ section.id }}-{{ i }}">
      
      {%- capture row_content -%}
        {%- for block in section.blocks -%}
          {%- assign row_num = block.settings.row_number | plus: 0 -%}
          {%- if row_num == i -%}
            <div class="fmcg-marquee-wall__item" {{ block.shopify_attributes }}>
              <span class="fmcg-marquee-wall__text" style="color: {{ block.settings.color }};">
                {{ block.settings.text | strip }}
              </span>
              
              {%- if block.settings.svg_code != blank -%}
                <div class="fmcg-marquee-wall__svg" style="color: {{ block.settings.color }};">
                  {{ block.settings.svg_code }}
                </div>
              {%- elsif block.settings.icon != blank -%}
                {{ block.settings.icon | image_url: width: 400 | image_tag: class: 'fmcg-marquee-wall__logo', loading: 'lazy' }}
              {%- elsif row_logo != blank -%}
                {{ row_logo | image_url: width: 400 | image_tag: class: 'fmcg-marquee-wall__logo', loading: 'lazy' }}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- if row_content != blank -%}
        <div class="fmcg-marquee-wall__row-items">
          {%- for j in (1..4) -%}
            <div class="fmcg-marquee-wall__group">{{ row_content }}</div>
          {%- endfor -%}
        </div>
      {%- else -%}
        {%- comment -%}Placeholder if no blocks{%- endcomment -%}
        <div class="fmcg-marquee-wall__item">
          <span class="fmcg-marquee-wall__text">Add Blocks to Row {{ i }}</span>
        </div>
      {%- endif -%}
    </div>
  {%- endfor -%}

</div>

<script>
  (function() {
    const section = document.getElementById('FmcgMarqueeWall-{{ section.id }}');
    if (!section) return;

    const rowEls = section.querySelectorAll('.fmcg-marquee-wall__row');
    const intensity = {{ section.settings.scroll_speed | default: 1.0 }};
    const autoSpeed = {{ section.settings.auto_speed | default: 30 }} / 60; // Convert to per-frame
    const lerpFactor = {{ section.settings.lerp_factor | default: 0.1 }};
    
    let targetScrollY = window.scrollY;
    let currentScrollValue = window.scrollY;
    let lastScrollValue = window.scrollY;
    
    // Initialize rows
    const rows = [...rowEls].map(row => {
      const group = row.querySelector('.fmcg-marquee-wall__group');
      return {
        el: row,
        width: group ? group.offsetWidth : 3000,
        dir: row.dataset.direction === 'left' ? -1 : 1,
        pos: Math.random() * 1000 // Random start for organic look
      };
    });
    
    function updatePositions() {
      // Smooth interpolation (LERP) for scroll value
      currentScrollValue += (targetScrollY - currentScrollValue) * lerpFactor;
      const scrollDelta = currentScrollValue - lastScrollValue;
      
      rows.forEach((r) => {
        // Combined pos: Auto-scroll + Scroll-linked Delta
        r.pos += (autoSpeed * r.dir) + (scrollDelta * intensity * r.dir);
        
        // Dynamic seamless loop
        const wrapWidth = r.width;
        r.pos = ((r.pos % wrapWidth) + wrapWidth) % wrapWidth;
        
        r.el.style.transform = `translate3d(${-r.pos}px, 0, 0)`;
      });
      
      lastScrollValue = currentScrollValue;
      requestAnimationFrame(updatePositions);
    }

    const onScroll = () => {
      targetScrollY = window.scrollY;
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    
    // Initial and periodic sync
    requestAnimationFrame(updatePositions);

    // Refresh widths on resize
    window.addEventListener('resize', () => {
      rows.forEach(r => {
        const group = r.el.querySelector('.fmcg-marquee-wall__group');
        if (group) r.width = group.offsetWidth;
      });
    });

    document.addEventListener('shopify:section:load', () => {
      targetScrollY = window.scrollY;
      currentScrollValue = window.scrollY;
      lastScrollValue = window.scrollY;
    });
  })();
</script>

{% schema %}
{
  "name": "FMCG Marquee Wall",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Extreme Typography"
    },
    { "type": "font_picker", "id": "font_family", "label": "Font Family", "default": "assistant_n4" },
    { "type": "range", "id": "fs_desktop", "label": "Desktop Size (rem)", "min": 2, "max": 50, "step": 1, "default": 8 },
    { "type": "range", "id": "fs_mobile", "label": "Mobile Size (rem)", "min": 1, "max": 30, "step": 0.5, "default": 3.5 },
    { "type": "select", "id": "fw", "label": "Font Weight", "options": [{"value":"100","label":"100 - Thin"},{"value":"200","label":"200 - Extra Light"},{"value":"300","label":"300 - Light"},{"value":"400","label":"400 - Normal"},{"value":"500","label":"500 - Medium"},{"value":"600","label":"600 - Semi Bold"},{"value":"700","label":"700 - Bold"},{"value":"800","label":"800 - Extra Bold"},{"value":"900","label":"900 - Black"}], "default": "900" },
    { "type": "range", "id": "ls", "label": "Letter Spacing (px)", "min": -10, "max": 30, "step": 1, "default": -2 },
    { "type": "select", "id": "text_transform", "label": "Text Transform", "options": [{"value":"none","label":"None"},{"value":"uppercase","label":"UPPERCASE"}], "default": "uppercase" },
    { "type": "range", "id": "row_gap", "label": "Vertical Row Gap", "min": 0, "max": 100, "step": 4, "default": 20 },
    { "type": "select", "id": "section_height", "label": "Min Section Height", "options": [{"value":"50vh","label":"Small"},{"value":"100vh","label":"Full Screen"}], "default": "100vh" },
    {
      "type": "header",
      "content": "Global Styles"
    },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "checkbox", "id": "use_outline", "label": "Enable Outline (Ghost) Mode", "default": false },
    { "type": "range", "id": "scroll_speed", "label": "Scroll Influence Intensity", "min": 0, "max": 5.0, "step": 0.1, "default": 1.2, "info": "How much scrolling speeds up the marquee." },
    { "type": "range", "id": "auto_speed", "label": "Base Auto-Scroll Speed", "min": 0, "max": 300, "step": 5, "default": 60, "info": "Pixels per second when not scrolling." },
    { "type": "range", "id": "lerp_factor", "label": "Animation Smoothness", "min": 0.01, "max": 0.5, "step": 0.01, "default": 0.08, "info": "Lower is smoother/floatier." },
    {
      "type": "header",
      "content": "Row Direction & Logos"
    },
    { "type": "select", "id": "dir_1", "label": "Row 1 Direction", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "image_picker", "id": "logo_1", "label": "Row 1 Logo" },
    { "type": "select", "id": "dir_2", "label": "Row 2 Direction", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "right" },
    { "type": "image_picker", "id": "logo_2", "label": "Row 2 Logo" },
    { "type": "select", "id": "dir_3", "label": "Row 3 Direction", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "image_picker", "id": "logo_3", "label": "Row 3 Logo" },
    { "type": "select", "id": "dir_4", "label": "Row 4 Direction", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "right" },
    { "type": "image_picker", "id": "logo_4", "label": "Row 4 Logo" }
  ],
  "blocks": [
    {
      "type": "word",
      "name": "Custom Word",
      "settings": [
        { "type": "text", "id": "text", "label": "Word", "default": "BRAND" },
        { "type": "color", "id": "color", "label": "Word Color", "default": "#000000" },
        { "type": "image_picker", "id": "icon", "label": "Custom Icon" },
        { "type": "textarea", "id": "svg_code", "label": "Custom SVG Code", "info": "Paste <svg>...</svg> code here for sharpest logos." },
        { "type": "select", "id": "row_number", "label": "Row Assignment", "options": [{"value":"1","label":"Row 1"},{"value":"2","label":"Row 2"},{"value":"3","label":"Row 3"},{"value":"4","label":"Row 4"}], "default": "1" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FMCG Marquee Wall",
      "blocks": [
        { "type": "word", "settings": { "text": "ORGANIC", "row_number": "1" } },
        { "type": "word", "settings": { "text": "HEALTHY", "row_number": "1" } },
        { "type": "word", "settings": { "text": "CRUNCHY", "row_number": "2" } },
        { "type": "word", "settings": { "text": "SNACKY", "row_number": "2" } }
      ]
    }
  ]
}
{% endschema %}
