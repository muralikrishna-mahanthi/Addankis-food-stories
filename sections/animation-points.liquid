{%- style -%}
  {%- liquid
    assign heading_font = section.settings.heading_font
    assign text_font = section.settings.text_font
  -%}

  {{ heading_font | font_face: font_display: 'swap' }}
  {{ text_font | font_face: font_display: 'swap' }}

  #AnimationPoints-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    overflow: hidden;
    font-family: {{ text_font.family }}, {{ text_font.fallback_families }};
  }

  .ap-container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 4rem;
    position: relative;
  }

  .ap-header {
    text-align: center;
    margin-bottom: 8rem;
    opacity: 0;
    transform: translateY(40px);
    transition: all 1s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .ap-header.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ap-heading {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
  }

  .ap-timeline {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 0;
  }

  .ap-line-wrapper {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    transform: translateX(-50%);
    background: {{ section.settings.line_base_color }};
    border-radius: 2px;
    z-index: 1;
  }

  .ap-line-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: {{ section.settings.line_active_color }};
    transition: height 0.1s linear;
    box-shadow: 0 0 10px {{ section.settings.line_active_color | color_modify: 'alpha', 0.4 }};
  }

  .ap-points-list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8rem;
    z-index: 2;
  }

  .ap-points-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
    opacity: 0;
    transform: translateY(50px);
    transition: all 1s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .ap-points-row.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ap-point-item {
    width: 42%;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .ap-point-left {
    text-align: right;
  }

  .ap-point-right {
    text-align: left;
  }

  .ap-point-dot {
    position: absolute;
    top: 3rem;
    width: 20px;
    height: 20px;
    background: {{ section.settings.bg_color }};
    border: 4px solid {{ section.settings.line_base_color }};
    border-radius: 50%;
    z-index: 5;
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .ap-point-left .ap-point-dot {
    right: -10.8%; /* Adjust to hit the center line */
    margin-right: -10px;
  }

  /* Fallback using fixed pixels for better precision if container width is known */
  @media screen and (min-width: 769px) {
    .ap-point-left .ap-point-dot {
        right: calc(-8rem - 11px);
    }
    .ap-point-right .ap-point-dot {
        left: calc(-8rem - 11px);
    }
  }

  .ap-points-row.is-active .ap-point-dot {
    background: {{ section.settings.line_active_color }};
    border-color: {{ section.settings.line_active_color }};
    transform: scale(1.4);
    box-shadow: 0 0 20px {{ section.settings.line_active_color | color_modify: 'alpha', 0.4 }};
  }

  .ap-point-block {
    background: {{ section.settings.block_bg_color }};
    padding: 3.5rem;
    border-radius: 2rem;
    box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    border: 1px solid rgba(255,255,255,0.2);
    backdrop-filter: blur(10px);
    transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.4s ease;
    width: 100%;
  }

  .ap-points-row:hover .ap-point-block {
    transform: translateY(-5px);
    box-shadow: 0 25px 50px rgba(0,0,0,0.08);
  }

  .ap-point-title {
    margin: 0 0 1rem 0;
    font-size: 2.4rem;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
  }

  .ap-point-desc {
    margin: 0;
    font-size: 1.6rem;
    line-height: 1.6;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.8 }};
  }

  @media screen and (max-width: 768px) {
    .ap-container {
      padding: 0 2rem;
    }
    .ap-line-wrapper {
      left: 2rem;
    }
    .ap-points-row {
      flex-direction: column;
      gap: 3rem;
      padding-left: 5rem;
    }
    .ap-point-item {
      width: 100%;
      text-align: left !important;
    }
    .ap-point-dot {
      left: -11px !important;
      right: auto !important;
    }
    .ap-heading {
      font-size: 3.2rem;
    }
  }
{%- endstyle -%}

<section id="AnimationPoints-{{ section.id }}" class="ap-section">
  <div class="ap-container">
    <div class="ap-header js-ap-animate">
      <h2 class="ap-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="ap-timeline">
      <div class="ap-line-wrapper">
        <div class="ap-line-fill js-ap-line-fill"></div>
      </div>

      <div class="ap-points-list">
        {%- comment -%} Group blocks in pairs of two {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if forloop.index0 % 2 == 0 -%}
            <div class="ap-points-row js-ap-row js-ap-animate">
              
              <!-- Left Point (Point 1, 3, 5...) -->
              <div class="ap-point-item ap-point-left" {{ block.shopify_attributes }}>
                <div class="ap-point-dot"></div>
                <div class="ap-point-block">
                  {%- if block.settings.title != blank -%}
                    <h3 class="ap-point-title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <div class="ap-point-desc">{{ block.settings.description }}</div>
                  {%- endif -%}
                </div>
              </div>

              <!-- Right Point (Point 2, 4, 6...) -->
              {%- assign next_index = forloop.index0 | plus: 1 -%}
              {%- assign next_block = section.blocks[next_index] -%}
              {%- if next_block != blank -%}
                <div class="ap-point-item ap-point-right" {{ next_block.shopify_attributes }}>
                  <div class="ap-point-dot"></div>
                  <div class="ap-point-block">
                    {%- if next_block.settings.title != blank -%}
                      <h3 class="ap-point-title">{{ next_block.settings.title }}</h3>
                    {%- endif -%}
                    {%- if next_block.settings.description != blank -%}
                      <div class="ap-point-desc">{{ next_block.settings.description }}</div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}

            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>


<script>
  function initAnimationPoints() {
    const section = document.querySelector('#AnimationPoints-{{ section.id }}');
    if (!section || section.dataset.initialized) return;
    section.dataset.initialized = "true";

    const animateElements = section.querySelectorAll('.js-ap-animate');
    const rows = section.querySelectorAll('.js-ap-row');
    const lineFill = section.querySelector('.js-ap-line-fill');
    
    // Intersection Observer for fade-in animations
    const observerOptions = {
      threshold: 0.05, // Lower threshold for better visibility
      rootMargin: "0px 0px -40px 0px"
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, observerOptions);

    animateElements.forEach(el => observer.observe(el));

    // Scroll listener for timeline line and dot activation
    function updateTimeline() {
      const rect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight;
      
      const sectionHeight = section.offsetHeight;
      const sectionTop = rect.top;
      
      // Calculate line progress
      const startTrigger = viewportHeight * 0.8; // Start earlier
      let progress = 0;
      
      if (sectionTop < startTrigger) {
          progress = (startTrigger - sectionTop) / (sectionHeight - viewportHeight * 0.2);
      }
      
      progress = Math.max(0, Math.min(1, progress));
      
      if (lineFill) {
        lineFill.style.height = (progress * 100) + '%';
      }

      rows.forEach(row => {
        const rowRect = row.getBoundingClientRect();
        // Activate dots in the row when it passes 65% of screen height
        if (rowRect.top < viewportHeight * 0.65) {
          row.classList.add('is-active');
        } else {
          row.classList.remove('is-active');
        }
      });
    }

    window.addEventListener('scroll', updateTimeline, { passive: true });
    updateTimeline(); // Initial check
    
    // Safety check: if an element is high up on the page, make it visible immediately
    setTimeout(() => {
        animateElements.forEach(el => {
            const r = el.getBoundingClientRect();
            // Using window.innerHeight here to avoid undefined variable
            if (r.top < window.innerHeight) el.classList.add('is-visible');
        });
    }, 500);
  }

  document.addEventListener('DOMContentLoaded', initAnimationPoints);
  document.addEventListener('shopify:section:load', (e) => {
    if (e.target.id.includes('{{ section.id }}')) {
      initAnimationPoints();
    }
  });
</script>


