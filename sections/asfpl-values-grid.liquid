{%- style -%}
  .values-grid-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
  }

  .values-grid__container {
    max-width: var(--page-width, 1400px);
    margin: 0 auto;
    padding: 0 4rem;
  }

  .values-grid__header {
    text-align: center;
    margin-bottom: 6rem;
  }

  .values-grid__preheading {
    font-size: 1.4rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: {{ section.settings.accent_color | default: '#3b82f6' }};
    margin-bottom: 1rem;
    display: block;
  }

  .values-grid__heading {
    font-size: clamp(3rem, 6vw, 6rem);
    font-weight: 950;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: {{ section.settings.text_color }};
  }

  .values-grid__items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }

  .values-grid__item {
    background: {{ section.settings.card_bg }};
    padding: 4rem;
    border-radius: 2rem;
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    opacity: 0;
    transform: translateY(30px);
  }

  .values-grid__item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .values-grid__item:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    background: {{ section.settings.card_hover_bg | default: '#fafafa' }};
  }

  .values-grid__icon {
    width: 60px;
    height: 60px;
    margin-bottom: 3rem;
    color: {{ section.settings.accent_color | default: '#3b82f6' }};
  }

  .values-grid__icon img,
  .values-grid__icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .values-grid__item-heading {
    font-size: 2.8rem;
    font-weight: 900;
    margin-bottom: 2rem;
    line-height: 1.1;
    color: {{ section.settings.text_color }};
    letter-spacing: -0.01em;
  }

  .values-grid__item-text {
    font-size: 1.8rem;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .values-grid__container {
      padding: 0 2rem;
    }
    .values-grid__heading {
      font-size: 4rem;
    }
    .values-grid__item {
      padding: 3rem;
    }
  }
{%- endstyle -%}

<section class="values-grid-{{ section.id }} values-grid">
  <div class="values-grid__container">
    
    {%- if section.settings.heading != blank -%}
      <div class="values-grid__header">
        {%- if section.settings.preheading != blank -%}
          <span class="values-grid__preheading">{{ section.settings.preheading }}</span>
        {%- endif -%}
        <h2 class="values-grid__heading">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="values-grid__items">
      {%- for block in section.blocks -%}
        <div class="values-grid__item values-grid-reveal" {{ block.shopify_attributes }}>
          <div class="values-grid__icon">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 120 | image_tag: loading: 'lazy' }}
            {%- elsif block.settings.svg_code != blank -%}
              {{ block.settings.svg_code }}
            {%- else -%}
              <svg width="60" height="60" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
                <path d="M7 8H17M7 12H17M7 16H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            {%- endif -%}
          </div>
          <h3 class="values-grid__item-heading">{{ block.settings.title }}</h3>
          <div class="values-grid__item-text">{{ block.settings.text }}</div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
  (function() {
    const observerOptions = {
      root: null,
      threshold: 0.1,
      rootMargin: '0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.values-grid-reveal').forEach((item) => {
      observer.observe(item);
    });
  })();
</script>

{% schema %}
{
  "name": "ASFPL Values Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#000000" },
    { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#3b82f6" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#f9f9f9" },
    { "type": "color", "id": "card_hover_bg", "label": "Card Hover Background", "default": "#ffffff" },
    { "type": "text", "id": "preheading", "label": "Pre-heading", "default": "OUR GUIDING LIGHT" },
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "COMMITTED TO EXCELLENCE" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top Padding", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom Padding", "default": 80 }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value Block",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Icon Image" },
        { "type": "html", "id": "svg_code", "label": "Override SVG Code" },
        { "type": "text", "id": "title", "label": "Value Name", "default": "Quality First" },
        { "type": "richtext", "id": "text", "label": "Description", "default": "<p>We source only the finest ingredients, ensuring that every product tells a story of uncompromising quality.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ASFPL Values Grid",
      "blocks": [
        { "type": "value", "settings": { "title": "Unrivaled Taste" } },
        { "type": "value", "settings": { "title": "Sustainable Growth" } },
        { "type": "value", "settings": { "title": "Community Focus" } }
      ]
    }
  ]
}
{% endschema %}
