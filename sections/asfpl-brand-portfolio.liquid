{%- style -%}
  .brand-portfolio-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
  }

  .brand-portfolio__container {
    max-width: var(--page-width, 1400px);
    margin: 0 auto;
    padding: 0 4rem;
  }

  .brand-portfolio__header {
    text-align: center;
    margin-bottom: 8rem;
  }

  .brand-portfolio__heading {
    font-size: clamp(3rem, 7vw, 7rem);
    font-weight: 950;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    color: {{ section.settings.text_color }};
  }

  .brand-portfolio__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 4rem;
    align-items: center;
  }

  .brand-portfolio__item {
    aspect-ratio: 3 / 2;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: {{ section.settings.card_bg }};
    border-radius: 1.5rem;
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    opacity: 0;
    transform: scale(0.9);
    filter: grayscale(100%);
    position: relative;
    overflow: hidden;
  }

  .brand-portfolio__item.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  .brand-portfolio__item:hover {
    filter: grayscale(0%);
    background: {{ section.settings.card_hover_bg | default: '#ffffff' }};
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  }

  .brand-portfolio__item img {
    max-width: 100%;
    max-height: 80%;
    object-fit: contain;
    transition: transform 0.5s ease;
  }

  .brand-portfolio__item:hover img {
    transform: scale(1.1);
  }

  .brand-portfolio__brand-name {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0;
    transition: all 0.3s ease;
    color: {{ section.settings.accent_color | default: '#3b82f6' }};
  }

  .brand-portfolio__item:hover .brand-portfolio__brand-name {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media screen and (max-width: 749px) {
    .brand-portfolio__container {
      padding: 0 2rem;
    }
    .brand-portfolio__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
    .brand-portfolio__heading {
      font-size: 4rem;
    }
  }
{%- endstyle -%}

<section class="brand-portfolio-{{ section.id }} brand-portfolio">
  <div class="brand-portfolio__container">
    
    {%- if section.settings.heading != blank -%}
      <div class="brand-portfolio__header">
        <h2 class="brand-portfolio__heading">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="brand-portfolio__grid">
      {%- for block in section.blocks -%}
        <div class="brand-portfolio__item brand-reveal-portfolio" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {{ 'logo' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          
          {%- if block.settings.brand_name != blank -%}
            <span class="brand-portfolio__brand-name">{{ block.settings.brand_name }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
  (function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.brand-reveal-portfolio').forEach((item) => {
      observer.observe(item);
    });
  })();
</script>

{% schema %}
{
  "name": "ASFPL Brand Portfolio",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#000000" },
    { "type": "color", "id": "card_bg", "label": "Logo Area Background", "default": "#f9f9f9" },
    { "type": "color", "id": "card_hover_bg", "label": "Logo Area Hover", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#3b82f6" },
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "OUR PORTFOLIO" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top Padding", "default": 100 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom Padding", "default": 100 }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand Logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Brand Logo" },
        { "type": "text", "id": "brand_name", "label": "Brand Name" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ASFPL Brand Portfolio",
      "blocks": [
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" }
      ]
    }
  ]
}
{% endschema %}
