{%- style -%}
  .about-us-scroll-{{ section.id }} {
    position: relative;
    --progress: 0;
    /* Height dynamic based on block count */
    height: {{ section.blocks.size | times: 100 }}vh;
  }

  .about-us-scroll__sticky {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    display: flex;
    overflow: hidden;
  }

  /* Split Layout */
  .about-us-scroll__left {
    flex: 1;
    position: relative;
    background: #000;
  }

  .about-us-scroll__right {
    flex: 1;
    position: relative;
    background: {{ section.settings.bg_color }};
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 5%;
  }

  @media screen and (max-width: 749px) {
    .about-us-scroll__sticky {
      flex-direction: column;
    }
    .about-us-scroll__left {
      height: 40vh;
      flex: none;
    }
    .about-us-scroll__right {
      height: 60vh;
      flex: none;
      padding: 3rem 1.5rem;
    }
  }

  /* Layers (Media & Content) */
  .about-us-scroll__media-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
    z-index: 1;
  }

  .about-us-scroll__media-layer img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-us-scroll__content-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: all 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
    transform: translateY(20px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 10%;
    z-index: 1;
    visibility: hidden;
  }

  .about-us-scroll__media-layer.active,
  .about-us-scroll__content-layer.active {
    opacity: 1;
    transform: translateY(0);
    z-index: 2;
    visibility: visible;
  }

  /* UI Elements: Pills */
  .about-us-scroll__pills {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .about-us-scroll__pill {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    font-weight: 800;
    border: 2px solid rgba(255,255,255,0.2);
    color: {{ section.settings.text_color }};
    transition: all 0.4s ease;
    background: transparent;
  }

  .about-us-scroll__pill.active {
    background: {{ section.settings.active_pill_bg | default: '#000000' }};
    border-color: {{ section.settings.active_pill_bg | default: '#000000' }};
    color: #ffffff;
    transform: scale(1.1);
  }

  /* Typography */
  .about-us-scroll__heading {
    font-size: clamp(3rem, 7vw, {{ section.settings.fs_desktop }}rem);
    font-weight: 950;
    line-height: 0.9;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    color: {{ section.settings.text_color }};
    margin-bottom: 3rem;
  }

  .about-us-scroll__text {
    font-size: 1.8rem;
    line-height: 1.5;
    color: {{ section.settings.text_color }};
    opacity: 0.9;
    margin-bottom: 4rem;
    max-width: 500px;
  }

  .about-us-scroll__btn {
    display: inline-flex;
    padding: 1.5rem 3.5rem;
    border-radius: 5rem;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text }};
    font-size: 1.2rem;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    width: fit-content;
    transition: all 0.3s ease;
  }

  .about-us-scroll__btn:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
  }
{%- endstyle -%}

<section class="about-us-scroll-{{ section.id }} about-us-scroll" id="AboutUsScroll-{{ section.id }}">
  <div class="about-us-scroll__sticky">
    
    <!-- Left: Media Stack -->
    <div class="about-us-scroll__left">
      {%- for block in section.blocks -%}
        <div class="about-us-scroll__media-layer {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {{ 'lifestyle-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <!-- Right: Content Stack -->
    <div class="about-us-scroll__right">
      
      <!-- Shared Pills -->
      <div class="about-us-scroll__pills">
        {%- for block in section.blocks -%}
          <div class="about-us-scroll__pill" data-index="{{ forloop.index0 }}">
            0{{ forloop.index }}
          </div>
        {%- endfor -%}
      </div>

      {%- for block in section.blocks -%}
        <div class="about-us-scroll__content-layer {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
          <h2 class="about-us-scroll__heading">{{ block.settings.heading }}</h2>
          <div class="about-us-scroll__text">{{ block.settings.text }}</div>
          {%- if block.settings.btn_label != blank -%}
            <a href="{{ block.settings.btn_link }}" class="about-us-scroll__btn">{{ block.settings.btn_label }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}

    </div>

  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('AboutUsScroll-{{ section.id }}');
    if (!section) return;

    const mediaLayers = section.querySelectorAll('.about-us-scroll__media-layer');
    const contentLayers = section.querySelectorAll('.about-us-scroll__content-layer');
    const pills = section.querySelectorAll('.about-us-scroll__pill');
    const totalBlocks = {{ section.blocks.size }};

    function handleScroll() {
      const rect = section.getBoundingClientRect();
      const sectionHeight = section.offsetHeight;
      const viewportHeight = window.innerHeight;
      
      // Calculate progress (0 to 1) based on sticky path
      // rect.top goes from 0 down to -(sectionHeight - viewportHeight)
      let progress = -rect.top / (sectionHeight - viewportHeight);
      progress = Math.max(0, Math.min(0.99, progress));
      
      // Determine active index
      const activeIndex = Math.floor(progress * totalBlocks);
      
      // Update Active Classes
      mediaLayers.forEach(l => l.classList.remove('active'));
      contentLayers.forEach(l => l.classList.remove('active'));
      pills.forEach(p => p.classList.remove('active'));

      if (mediaLayers[activeIndex]) mediaLayers[activeIndex].classList.add('active');
      if (contentLayers[activeIndex]) contentLayers[activeIndex].classList.add('active');
      if (pills[activeIndex]) pills[activeIndex].classList.add('active');
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); // Initial call
  })();
</script>

{% schema %}
{
  "name": "About Us Scroll",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Right Background", "default": "#3b82f6" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#ffffff" },
    { "type": "color", "id": "active_pill_bg", "label": "Active Pill Color", "default": "#000000" },
    { "type": "color", "id": "btn_bg", "label": "Button Background", "default": "#000000" },
    { "type": "color", "id": "btn_text", "label": "Button Text", "default": "#ffffff" },
    { "type": "range", "id": "fs_desktop", "label": "Heading Size (Desktop)", "min": 2, "max": 12, "step": 0.5, "unit": "rem", "default": 6.5 }
  ],
  "blocks": [
    {
      "type": "story_phase",
      "name": "Story Phase",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Media" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "FOOD. DRINKS. SMILES." },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Built with high-quality ingredients, deep connections with consumers, and iconic brands." },
        { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Explore Our Mission" },
        { "type": "url", "id": "btn_link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Us Scroll",
      "blocks": [
        { "type": "story_phase", "settings": { "heading": "Chapter One" } },
        { "type": "story_phase", "settings": { "heading": "Chapter Two" } },
        { "type": "story_phase", "settings": { "heading": "Chapter Three" } }
      ]
    }
  ]
}
{% endschema %}
