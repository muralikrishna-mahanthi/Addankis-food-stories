{%- style -%}
  .about-us-split-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    background-color: {{ section.settings.bg_color }};
  }

  .about-us-split__left {
    width: 50%;
    position: relative;
    min-height: 100vh;
  }

  .about-us-split__left img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* When there is no image but full height is wanted */
  .about-us-split__left .placeholder-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #e5e5e5;
  }

  .about-us-split__right {
    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 8%;
  }

  @media screen and (max-width: 749px) {
    .about-us-split__left,
    .about-us-split__right {
      width: 100%;
    }
    .about-us-split__left {
      height: 50vh;
      min-height: unset;
    }
    .about-us-split__right {
      padding: 4rem 1.5rem;
    }
  }

  /* Pills Block */
  .about-us-split__pills {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .about-us-split__pill {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    line-height: 1;
  }

  /* Reset default margins for clean stack */
  .about-us-split__heading,
  .about-us-split__text {
    margin: 0;
  }

  /* Richtext specific overrides */
  .about-us-split__text p {
    margin: 0 0 1rem 0;
  }
  .about-us-split__text p:last-child {
    margin: 0;
  }

  .about-us-split__btn {
    display: inline-flex;
    text-decoration: none;
    align-items: center;
    justify-content: center;
    border-radius: 50px;
    line-height: 1;
    transition: all 0.3s ease;
  }
  .about-us-split__btn:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }
{%- endstyle -%}

<section class="about-us-split-{{ section.id }}" id="AboutUsSplit-{{ section.id }}">
  <div class="about-us-split__left">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy' }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="about-us-split__right">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        
        {%- when 'pills' -%}
          {{ block.settings.font_family | font_face: display: 'swap' }}
          <div class="about-us-split__pills" {{ block.shopify_attributes }} style="
            padding-top: {{ block.settings.padding_top }}px;
            padding-bottom: {{ block.settings.padding_bottom }}px;
          ">
            {%- for i in (1..3) -%}
              <div class="about-us-split__pill" style="
                width: {{ block.settings.pill_size }}rem;
                height: {{ block.settings.pill_size }}rem;
                font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
                font-weight: {{ block.settings.font_weight }};
                font-size: {{ block.settings.pill_size | divided_by: 2.2 }}rem;
                {% if forloop.first %}
                  background-color: {{ block.settings.active_bg_color }};
                  color: {{ block.settings.active_text_color }};
                {% else %}
                  background-color: {{ block.settings.inactive_bg_color }};
                  color: {{ block.settings.inactive_text_color }};
                {% endif %}
              ">
                0{{ i }}
              </div>
            {%- endfor -%}
          </div>

        {%- when 'heading' -%}
          {{ block.settings.font_family | font_face: display: 'swap' }}
          <h2 class="about-us-split__heading" {{ block.shopify_attributes }} style="
            padding-top: {{ block.settings.padding_top }}px;
            padding-bottom: {{ block.settings.padding_bottom }}px;
            font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
            font-weight: {{ block.settings.font_weight }};
            font-size: clamp(3rem, 6vw, {{ block.settings.font_size }}rem);
            color: {{ block.settings.text_color }};
            line-height: 1.05;
          ">
            {{ block.settings.text | newline_to_br }}
          </h2>

        {%- when 'text' -%}
          {{ block.settings.font_family | font_face: display: 'swap' }}
          <div class="about-us-split__text" {{ block.shopify_attributes }} style="
            padding-top: {{ block.settings.padding_top }}px;
            padding-bottom: {{ block.settings.padding_bottom }}px;
            font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
            font-weight: {{ block.settings.font_weight }};
            font-size: {{ block.settings.font_size }}rem;
            color: {{ block.settings.text_color }};
            line-height: 1.5;
          ">
            {{ block.settings.text }}
          </div>

        {%- when 'button' -%}
          {{ block.settings.font_family | font_face: display: 'swap' }}
          <div {{ block.shopify_attributes }} style="
            padding-top: {{ block.settings.padding_top }}px;
            padding-bottom: {{ block.settings.padding_bottom }}px;
          ">
            <a href="{{ block.settings.link | default: '#' }}" class="about-us-split__btn" style="
              padding: {{ block.settings.btn_padding_y }}rem {{ block.settings.btn_padding_x }}rem;
              font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
              font-weight: {{ block.settings.font_weight }};
              font-size: {{ block.settings.font_size }}rem;
              background-color: {{ block.settings.bg_color }};
              color: {{ block.settings.text_color }};
            ">
              {{ block.settings.text }}
            </a>
          </div>
          
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "About Us Side-by-Side",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Section Image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Right Section Background Color",
      "default": "#3A81F4"
    }
  ],
  "blocks": [
    {
      "type": "pills",
      "name": "Number Pills",
      "limit": 1,
      "settings": [
        { "type": "header", "content": "Spacing" },
        { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 0, "max": 100, "step": 2, "default": 0, "unit": "px" },
        { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 100, "step": 2, "default": 20, "unit": "px" },
        
        { "type": "header", "content": "Typography & Sizing" },
        { "type": "font_picker", "id": "font_family", "label": "Font Family", "default": "sans-serif" },
        { "type": "range", "id": "font_weight", "label": "Font Weight", "min": 100, "max": 900, "step": 100, "default": 800 },
        { "type": "range", "id": "pill_size", "label": "Pill Size", "min": 2, "max": 8, "step": 0.5, "default": 3.5, "unit": "rem" },
        
        { "type": "header", "content": "Colors" },
        { "type": "color", "id": "active_bg_color", "label": "Active Background", "default": "#003A6A" },
        { "type": "color", "id": "active_text_color", "label": "Active Text", "default": "#FFFFFF" },
        { "type": "color", "id": "inactive_bg_color", "label": "Inactive Background", "default": "#A0C4FA" },
        { "type": "color", "id": "inactive_text_color", "label": "Inactive Text", "default": "#FFFFFF" }
      ]
    },
    {
      "type": "heading",
      "name": "Heading Block",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Heading Text", "default": "FOOD. DRINKS.\nSMILES." },
        
        { "type": "header", "content": "Spacing" },
        { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 0, "max": 100, "step": 2, "default": 0, "unit": "px" },
        { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 100, "step": 2, "default": 40, "unit": "px" },
        
        { "type": "header", "content": "Typography" },
        { "type": "font_picker", "id": "font_family", "label": "Font Family", "default": "sans-serif" },
        { "type": "range", "id": "font_weight", "label": "Font Weight", "min": 100, "max": 900, "step": 100, "default": 900 },
        { "type": "range", "id": "font_size", "label": "Font Size", "min": 2, "max": 12, "step": 0.5, "default": 6.5, "unit": "rem" },
        { "type": "color", "id": "text_color", "label": "Text Color", "default": "#003A6A" }
      ]
    },
    {
      "type": "text",
      "name": "Text Block",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Description Text", "default": "<p>Built with high-quality ingredients, deep connections with consumers, and iconic brands. Step inside PepsiCo and see how we're bringing the world more reasons to smile.</p>" },
        
        { "type": "header", "content": "Spacing" },
        { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 0, "max": 100, "step": 2, "default": 0, "unit": "px" },
        { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 100, "step": 2, "default": 40, "unit": "px" },
        
        { "type": "header", "content": "Typography" },
        { "type": "font_picker", "id": "font_family", "label": "Font Family", "default": "sans-serif" },
        { "type": "range", "id": "font_weight", "label": "Font Weight", "min": 100, "max": 900, "step": 100, "default": 500 },
        { "type": "range", "id": "font_size", "label": "Font Size", "min": 1, "max": 4, "step": 0.1, "default": 1.6, "unit": "rem" },
        { "type": "color", "id": "text_color", "label": "Text Color", "default": "#FFFFFF" }
      ]
    },
    {
      "type": "button",
      "name": "Button Block",
      "settings": [
        { "type": "text", "id": "text", "label": "Button Text", "default": "Explore Our Mission" },
        { "type": "url", "id": "link", "label": "Button Link" },
        
        { "type": "header", "content": "Spacing (Block)" },
        { "type": "range", "id": "padding_top", "label": "Block Padding Top", "min": 0, "max": 100, "step": 2, "default": 0, "unit": "px" },
        { "type": "range", "id": "padding_bottom", "label": "Block Padding Bottom", "min": 0, "max": 100, "step": 2, "default": 0, "unit": "px" },
        
        { "type": "header", "content": "Spacing (Internal Button)" },
        { "type": "range", "id": "btn_padding_x", "label": "Horizontal Padding", "min": 1, "max": 8, "step": 0.5, "default": 3.0, "unit": "rem" },
        { "type": "range", "id": "btn_padding_y", "label": "Vertical Padding", "min": 0.5, "max": 4, "step": 0.1, "default": 1.2, "unit": "rem" },
        
        { "type": "header", "content": "Typography" },
        { "type": "font_picker", "id": "font_family", "label": "Font Family", "default": "sans-serif" },
        { "type": "range", "id": "font_weight", "label": "Font Weight", "min": 100, "max": 900, "step": 100, "default": 700 },
        { "type": "range", "id": "font_size", "label": "Font Size", "min": 1, "max": 3, "step": 0.1, "default": 1.4, "unit": "rem" },
        
        { "type": "header", "content": "Colors" },
        { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#003A6A" },
        { "type": "color", "id": "text_color", "label": "Text Color", "default": "#FFFFFF" }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Us Side-by-Side",
      "blocks": [
        { "type": "pills" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
