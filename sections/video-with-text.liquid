{%- style -%}
  .vwt-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .vwt-video-wrapper-{{ section.id }} {
    width: 100%;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .vwt-video-{{ section.id }} {
    width: {{ section.settings.video_width_desktop }}%;
    max-width: 100%;
    /* Constraints to keep the video looking neat */
    max-height: 90vh;
    object-fit: cover; /* Cover or contain based on preference, cover usually looks best if bounded */
    border-radius: {{ section.settings.border_radius }}px;
    display: block;
    background-color: #000; /* In case the video takes a second to load */
  }

  /* Placeholder Styling */
  .vwt-placeholder-{{ section.id }} {
    width: {{ section.settings.video_width_desktop }}%;
    aspect-ratio: 16/9;
    background: #e0e0e0;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: {{ section.settings.border_radius }}px;
    color: #333;
    font-size: 1.5rem;
    font-weight: bold;
    text-shadow: 0 1px 0 rgba(255,255,255,0.5);
  }

  .vwt-text-container-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 2rem;
    padding-right: 2rem;
    max-width: 900px;
    margin: 0 auto;
    text-align: {{ section.settings.text_alignment }};
  }

  .vwt-heading-{{ section.id }} {
    font-size: clamp(2rem, 5vw, 4rem);
    margin-bottom: 1.5rem;
    line-height: 1.1;
    font-weight: 700;
    color: {{ section.settings.text_color }};
  }

  .vwt-description-{{ section.id }} {
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    opacity: 0.9;
  }

  @media screen and (max-width: 749px) {
    .vwt-video-{{ section.id }},
    .vwt-placeholder-{{ section.id }} {
      width: {{ section.settings.video_width_mobile }}%;
    }
    
    .vwt-text-container-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
      padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
    }
  }
{%- endstyle -%}

<div class="vwt-section-{{ section.id }}">
  
  <!-- Top Full viewport block for Video -->
  <div class="vwt-video-wrapper-{{ section.id }}">
    {%- if section.settings.video != blank -%}
      {%- assign video_class = 'vwt-video-' | append: section.id -%}
      {{ section.settings.video | video_tag: 
          autoplay: section.settings.autoplay, 
          loop: section.settings.loop, 
          muted: section.settings.muted, 
          controls: section.settings.controls, 
          class: video_class, 
          image_size: '1200x' 
      }}
    {%- else -%}
      <div class="vwt-placeholder-{{ section.id }}">
        Upload a Shopify Video via Settings
      </div>
    {%- endif -%}
  </div>

  <!-- Bottom block for Text -->
  <div class="vwt-text-container-{{ section.id }}">
    {%- if section.settings.heading != blank -%}
      <h2 class="vwt-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
    {%- endif -%}
    
    {%- if section.settings.description != blank -%}
      <div class="vwt-description-{{ section.id }}">
        {{ section.settings.description }}
      </div>
    {%- endif -%}
  </div>
  
</div>

{% schema %}
{
  "name": "Video with Text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Video Settings"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-hosted Video",
      "info": "Upload or select a video from your Shopify files."
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Mute video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show controls",
      "default": false
    },
    {
      "type": "range",
      "id": "video_width_desktop",
      "label": "Desktop Video View Width (%)",
      "min": 30,
      "max": 100,
      "step": 5,
      "default": 50,
      "info": "Set to 50% to leave 25% free space on left and right."
    },
    {
      "type": "range",
      "id": "video_width_mobile",
      "label": "Mobile Video View Width (%)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 90
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Video Corner Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Introducing the Future"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Combine an impactful video with compelling text to tell your brand story below the viewport.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {"value": "left", "label": "Left"},
        {"value": "center", "label": "Center"},
        {"value": "right", "label": "Right"}
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Styling & Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 8,
      "unit": "px",
      "label": "Text Area Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 8,
      "unit": "px",
      "label": "Text Area Bottom Padding",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Video with Text"
    }
  ]
}
{% endschema %}
