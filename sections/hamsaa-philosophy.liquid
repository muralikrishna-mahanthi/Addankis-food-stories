{%- style -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.desc_font | font_face: font_display: 'swap' }}

  #HamsaaPhilosophy-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.pt_mobile }}px 0 {{ section.settings.pb_mobile }}px;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    #HamsaaPhilosophy-{{ section.id }} {
      padding: {{ section.settings.pt_desktop }}px 0 {{ section.settings.pb_desktop }}px;
    }
  }

  .hamsaa-philosophy__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  @media screen and (min-width: 750px) {
    .hamsaa-philosophy__container {
      flex-direction: {% if section.settings.layout == 'image_first' %}row{% else %}row-reverse{% endif %};
      align-items: center;
      gap: 8rem;
    }
  }

  /* Image Part with Frosted Glass Border */
  .hamsaa-philosophy__image-part {
    flex: 1;
    position: relative;
    opacity: 0;
    transform: translateX({% if section.settings.layout == 'image_first' %}-50px{% else %}50px{% endif %});
    transition: all 1.2s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .hamsaa-philosophy__image-wrapper {
    position: relative;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: {{ section.settings.image_radius }}px;
  }

  .hamsaa-philosophy__image-part img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ section.settings.image_radius | minus: 15 | at_least: 0 }}px;
    filter: grayscale({{ section.settings.image_grayscale }}%);
  }

  /* Text Part with Kinetic Reveal */
  .hamsaa-philosophy__text-part {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .hamsaa-philo__label {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.215, 0.61, 0.355, 1) 0.2s;
  }

  .hamsaa-philo__heading {
    margin: 0 0 2.5rem;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.215, 0.61, 0.355, 1) 0.4s;
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }} !important;
    font-size: {{ section.settings.heading_size_mobile }}rem !important;
    font-weight: {{ section.settings.heading_weight }} !important;
    font-style: {{ section.settings.heading_style }} !important;
    color: {{ section.settings.heading_color }} !important;
    line-height: 1.2 !important;
  }

  .hamsaa-philo__description {
    margin: 0;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.215, 0.61, 0.355, 1) 0.6s;
    font-family: {{ section.settings.desc_font.family }}, {{ section.settings.desc_font.fallback_families }} !important;
    font-size: {{ section.settings.desc_size_mobile }}px !important;
    font-weight: {{ section.settings.desc_weight }} !important;
    color: {{ section.settings.desc_color }} !important;
    line-height: 1.8 !important;
  }

  @media screen and (min-width: 750px) {
    .hamsaa-philo__heading {
      font-size: {{ section.settings.heading_size_desktop }}rem !important;
    }
    .hamsaa-philo__description {
      font-size: {{ section.settings.desc_size_desktop }}px !important;
    }
  }

  /* Visibility Trigger */
  #HamsaaPhilosophy-{{ section.id }}.is-visible .hamsaa-philosophy__image-part {
    opacity: 1;
    transform: translateX(0);
  }
  #HamsaaPhilosophy-{{ section.id }}.is-visible .hamsaa-philo__label,
  #HamsaaPhilosophy-{{ section.id }}.is-visible .hamsaa-philo__heading,
  #HamsaaPhilosophy-{{ section.id }}.is-visible .hamsaa-philo__description {
    opacity: 1;
    transform: translateY(0);
  }

  .hamsaa-philo__hr {
    width: 60px;
    height: 1px;
    background: {{ section.settings.accent_color }};
    margin: 3rem 0;
    opacity: 0;
    transition: all 1s ease 0.8s;
  }
  #HamsaaPhilosophy-{{ section.id }}.is-visible .hamsaa-philo__hr {
    opacity: 1;
    width: 100px;
  }
{%- endstyle -%}

<section id="HamsaaPhilosophy-{{ section.id }}" class="hamsaa-philosophy">
  <div class="hamsaa-philosophy__container">
    
    <div class="hamsaa-philosophy__image-part">
      <div class="hamsaa-philosophy__image-wrapper">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '600, 800, 1000, 1200' }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>

    <div class="hamsaa-philosophy__text-part">
      {%- if section.settings.label != blank -%}
        <div class="hamsaa-philo__label">{{ section.settings.label }}</div>
      {%- endif -%}
      
      {%- if section.settings.heading != blank -%}
        <h2 class="hamsaa-philo__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="hamsaa-philo__hr"></div>

      {%- if section.settings.description != blank -%}
        <div class="hamsaa-philo__description">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('HamsaaPhilosophy-{{ section.id }}');
    if (!section) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          section.classList.add('is-visible');
        }
      });
    }, { threshold: 0.2 });

    observer.observe(section);
    
    document.addEventListener('shopify:section:load', () => {
      section.classList.add('is-visible');
    });
  })();
</script>

{% schema %}
{
  "name": "HAMSAA philosophy Story",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    { "type": "select", "id": "layout", "label": "Image Position (Desktop)", "options": [{"value":"image_first","label":"Left"},{"value":"text_first","label":"Right"}], "default": "image_first" },
    { "type": "range", "id": "container_width", "label": "Container Width", "min": 800, "max": 1400, "step": 50, "default": 1200 },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "label", "label": "Top Label", "default": "Our Philosophy" },
    { "type": "text", "id": "heading", "label": "Heading Text", "default": "The Crystalline Soul of HAMSAA" },
    { "type": "richtext", "id": "description", "label": "Description Text", "default": "<p>Hamsaa represents the breath and the swan—a symbol of purity and ultimate clarity. Our camphor is refined to capture this elemental energy, bringing ancient wellness into your modern sanctuary.</p>" },
    { "type": "header", "content": "Typography - Heading" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading Font", "default": "assistant_n4" },
    { "type": "range", "id": "heading_size_desktop", "label": "Font Size (Desktop)", "min": 20, "max": 100, "step": 2, "unit": "px", "default": 48 },
    { "type": "range", "id": "heading_size_mobile", "label": "Font Size (Mobile)", "min": 20, "max": 60, "step": 2, "unit": "px", "default": 32 },
    { "type": "select", "id": "heading_weight", "label": "Font Weight", "options": [{"value":"400","label":"Regular"},{"value":"700","label":"Bold"},{"value":"900","label":"Black"}], "default": "700" },
    { "type": "select", "id": "heading_style", "label": "Font Style", "options": [{"value":"normal","label":"Normal"},{"value":"italic","label":"Italic"}], "default": "normal" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#1a1a1a" },
    { "type": "header", "content": "Typography - Description" },
    { "type": "font_picker", "id": "desc_font", "label": "Description Font", "default": "assistant_n4" },
    { "type": "range", "id": "desc_size_desktop", "label": "Font Size (Desktop)", "min": 14, "max": 24, "step": 1, "default": 18 },
    { "type": "range", "id": "desc_size_mobile", "label": "Font Size (Mobile)", "min": 14, "max": 22, "step": 1, "default": 16 },
    { "type": "select", "id": "desc_weight", "label": "Font Weight", "options": [{"value":"300","label":"Light"},{"value":"400","label":"Regular"}], "default": "400" },
    { "type": "color", "id": "desc_color", "label": "Description Color", "default": "#4a4a4a" },
    { "type": "header", "content": "Visual Styling" },
    { "type": "image_picker", "id": "image", "label": "Story Image" },
    { "type": "range", "id": "image_radius", "label": "Image/Frame Radius", "min": 0, "max": 100, "step": 5, "default": 0 },
    { "type": "range", "id": "image_grayscale", "label": "Image Grayscale %", "min": 0, "max": 100, "step": 10, "default": 0 },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent Color (Label/HR)", "default": "#c5a47e" },
    { "type": "header", "content": "Section Spacing" },
    { "type": "range", "id": "pt_desktop", "label": "Top Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 },
    { "type": "range", "id": "pb_desktop", "label": "Bottom Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 },
    { "type": "range", "id": "pt_mobile", "label": "Top Padding (Mobile)", "min": 0, "max": 150, "step": 5, "default": 60 },
    { "type": "range", "id": "pb_mobile", "label": "Bottom Padding (Mobile)", "min": 0, "max": 150, "step": 5, "default": 60 }
  ],
  "presets": [
    {
      "name": "HAMSAA philosophy Story"
    }
  ]
}
{% endschema %}
