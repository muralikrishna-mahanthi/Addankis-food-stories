{%- style -%}
  .about-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: {{ section.settings.bg_color }};
  }

  .about-hero__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .about-hero__media img,
  .about-hero__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness({{ section.settings.overlay_brightness }}%);
  }

  .about-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 1000px;
    padding: 0 2rem;
    color: {{ section.settings.text_color }};
  }

  .about-hero__heading {
    font-size: clamp(3.5rem, 8vw, {{ section.settings.fs_desktop }}rem);
    font-weight: 950;
    line-height: 0.9;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(40px);
    transition: all 1s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .about-hero__subheading {
    font-size: clamp(1.2rem, 3vw, 2.4rem);
    font-weight: 400;
    line-height: 1.4;
    opacity: 0;
    transform: translateY(20px);
    transition: all 1s cubic-bezier(0.19, 1, 0.22, 1);
    transition-delay: 0.3s;
  }

  .about-hero__indicator {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    animation: aboutHeroBounce 2s infinite;
    opacity: 0;
    transition: opacity 1s ease 1s;
  }

  .about-hero-active .about-hero__heading,
  .about-hero-active .about-hero__subheading,
  .about-hero-active .about-hero__indicator {
    opacity: 1;
    transform: translate(0);
  }

  @keyframes aboutHeroBounce {
    0%, 20%, 50%, 80%, 100% { transform: translate(-50%, 0); }
    40% { transform: translate(-50%, -10px); }
    60% { transform: translate(-50%, -5px); }
  }
{%- endstyle -%}

<div class="about-hero-{{ section.id }} about-hero" id="AboutHero-{{ section.id }}">
  <div class="about-hero__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2500 | image_tag: loading: 'eager' }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="about-hero__content">
    <h1 class="about-hero__heading">{{ section.settings.heading }}</h1>
    <div class="about-hero__subheading">{{ section.settings.subheading }}</div>
  </div>

  <div class="about-hero__indicator">
    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M7 13L12 18L17 13M7 6L12 11L17 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</div>

<script>
  (function() {
    const hero = document.getElementById('AboutHero-{{ section.id }}');
    if (!hero) return;
    
    // Trigger animation on load
    setTimeout(() => {
      hero.classList.add('about-hero-active');
    }, 100);
  })();
</script>

{% schema %}
{
  "name": "ASFPL Vision Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background Image" },
    { "type": "video", "id": "video", "label": "Background Video" },
    { "type": "range", "id": "overlay_brightness", "label": "Media Brightness", "min": 20, "max": 100, "step": 5, "default": 70 },
    { "type": "color", "id": "bg_color", "label": "Backup Background", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#ffffff" },
    { "type": "text", "id": "heading", "label": "Main Vision", "default": "BUILDING THE FUTURE OF FLAVOR." },
    { "type": "textarea", "id": "subheading", "label": "Subtext", "default": "Addanki’s Food Stories is more than a brand; it’s an ecosystem of taste, tradition, and innovation." },
    { "type": "range", "id": "fs_desktop", "label": "Heading Size (Desktop)", "min": 4, "max": 15, "step": 0.5, "default": 8 }
  ],
  "presets": [
    { "name": "ASFPL Vision Hero" }
  ]
}
{% endschema %}
