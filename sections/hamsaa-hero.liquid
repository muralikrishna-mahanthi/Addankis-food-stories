{%- style -%}
  /* Font Face Registrations */
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.desc_font | font_face: font_display: 'swap' }}

  #HamsaaHero-{{ section.id }} {
    --progress: 0;
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.pt_mobile }}px 0 {{ section.settings.pb_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    #HamsaaHero-{{ section.id }} {
      min-height: 100vh;
      padding: {{ section.settings.pt_desktop }}px 0 {{ section.settings.pb_desktop }}px;
    }
  }

  /* Background Crystal Effect */
  .hamsaa-hero__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hamsaa-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness({{ section.settings.bg_brightness }}%) blur({{ section.settings.bg_blur }}px);
    transition: transform 1.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  #HamsaaHero-{{ section.id }}.is-visible .hamsaa-hero__bg img {
    transform: scale(1.05);
  }

  .hamsaa-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .hamsaa-hero__container {
    position: relative;
    z-index: 3;
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
    text-align: {{ section.settings.text_alignment }};
  }

  /* Staggered Entrance Animations */
  .hamsaa-hero__heading {
    margin: 0 0 2rem;
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.215, 0.61, 0.355, 1);
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }} !important;
    font-size: {{ section.settings.heading_size_mobile }}rem !important;
    font-weight: {{ section.settings.heading_weight }} !important;
    font-style: {{ section.settings.heading_style }} !important;
    color: {{ section.settings.heading_color }} !important;
    line-height: {{ section.settings.heading_line_height }} !important;
    letter-spacing: {{ section.settings.heading_letter_spacing }}px !important;
    text-transform: {{ section.settings.heading_transform }} !important;
  }

  .hamsaa-hero__description {
    margin: 0 0 3rem;
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.215, 0.61, 0.355, 1) 0.2s;
    font-family: {{ section.settings.desc_font.family }}, {{ section.settings.desc_font.fallback_families }} !important;
    font-size: {{ section.settings.desc_size_mobile }}px !important;
    font-weight: {{ section.settings.desc_weight }} !important;
    font-style: {{ section.settings.desc_style }} !important;
    color: {{ section.settings.desc_color }} !important;
    line-height: 1.6 !important;
    max-width: 800px;
    {% if section.settings.text_alignment == 'center' %}margin-left: auto; margin-right: auto;{% endif %}
  }

  .hamsaa-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.215, 0.61, 0.355, 1) 0.4s;
  }

  #HamsaaHero-{{ section.id }}.is-visible .hamsaa-hero__heading,
  #HamsaaHero-{{ section.id }}.is-visible .hamsaa-hero__description,
  #HamsaaHero-{{ section.id }}.is-visible .hamsaa-hero__buttons {
    opacity: 1;
    transform: translateY(0);
  }

  @media screen and (min-width: 750px) {
    .hamsaa-hero__heading {
      font-size: {{ section.settings.heading_size_desktop }}rem !important;
    }
    .hamsaa-hero__description {
      font-size: {{ section.settings.desc_size_desktop }}px !important;
    }
  }

  /* Kinetic Typography Effect (Pulse Weight on Hover if Font Supports) */
  .hamsaa-hero__heading:hover {
     letter-spacing: {{ section.settings.heading_letter_spacing | plus: 2 }}px !important;
  }

  .hamsaa-btn {
    display: inline-flex;
    padding: 1.5rem 3.5rem;
    text-decoration: none !important;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    border-radius: {{ section.settings.btn_radius }}px;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .hamsaa-btn--primary {
    background: {{ section.settings.btn_primary_bg }};
    color: {{ section.settings.btn_primary_text }};
  }

  .hamsaa-btn--secondary {
    background: transparent;
    color: {{ section.settings.btn_secondary_text }};
    border: 1px solid {{ section.settings.btn_secondary_text }};
  }

  .hamsaa-btn:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    filter: brightness(1.1);
  }
{%- endstyle -%}

<section id="HamsaaHero-{{ section.id }}" class="hamsaa-hero">
  <div class="hamsaa-hero__bg">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', widths: '800, 1200, 1600, 2000' }}
    {%- else -%}
      <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);"></div>
    {%- endif -%}
  </div>
  
  <div class="hamsaa-hero__overlay"></div>

  <div class="hamsaa-hero__container">
    {%- if section.settings.heading != blank -%}
      <h1 class="hamsaa-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    
    {%- if section.settings.description != blank -%}
      <div class="hamsaa-hero__description">{{ section.settings.description }}</div>
    {%- endif -%}

    <div class="hamsaa-hero__buttons">
      {%- if section.settings.btn1_label != blank -%}
        <a href="{{ section.settings.btn1_link }}" class="hamsaa-btn hamsaa-btn--primary">
          {{ section.settings.btn1_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.btn2_label != blank -%}
        <a href="{{ section.settings.btn2_link }}" class="hamsaa-btn hamsaa-btn--secondary">
          {{ section.settings.btn2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('HamsaaHero-{{ section.id }}');
    if (!section) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          section.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1 });

    observer.observe(section);
    
    // Theme Editor Re-Sync
    document.addEventListener('shopify:section:load', () => {
      section.classList.add('is-visible');
    });
  })();
</script>

{% schema %}
{
  "name": "HAMSAA Hero Reveal",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Core Content"
    },
    { "type": "text", "id": "heading", "label": "Heading Text", "default": "Elevate Your Soul" },
    { "type": "richtext", "id": "description", "label": "Intro Paragraph", "default": "<p>Discover the pure essence of Camphor. A sanctuary for the senses, crafted for clarity and wellness.</p>" },
    { "type": "header", "content": "Typography - Heading" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading Font", "default": "assistant_n4" },
    { "type": "range", "id": "heading_size_desktop", "label": "Font Size (Desktop)", "min": 2, "max": 12, "step": 0.5, "unit": "rem", "default": 6.5 },
    { "type": "range", "id": "heading_size_mobile", "label": "Font Size (Mobile)", "min": 2, "max": 8, "step": 0.5, "unit": "rem", "default": 3.5 },
    { "type": "select", "id": "heading_weight", "label": "Font Weight", "options": [{"value":"100","label":"Thin"},{"value":"400","label":"Regular"},{"value":"700","label":"Bold"},{"value":"900","label":"Black"}], "default": "700" },
    { "type": "select", "id": "heading_style", "label": "Font Style", "options": [{"value":"normal","label":"Normal"},{"value":"italic","label":"Italic"}], "default": "normal" },
    { "type": "select", "id": "heading_transform", "label": "Text Transform", "options": [{"value":"none","label":"None"},{"value":"uppercase","label":"Uppercase"}], "default": "uppercase" },
    { "type": "range", "id": "heading_line_height", "label": "Line Height", "min": 0.8, "max": 2.0, "step": 0.1, "default": 1.1 },
    { "type": "range", "id": "heading_letter_spacing", "label": "Letter Spacing (px)", "min": -5, "max": 20, "step": 1, "default": 2 },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#ffffff" },
    { "type": "header", "content": "Typography - Description" },
    { "type": "font_picker", "id": "desc_font", "label": "Description Font", "default": "assistant_n4" },
    { "type": "range", "id": "desc_size_desktop", "label": "Font Size (Desktop)", "min": 12, "max": 30, "step": 1, "unit": "px", "default": 20 },
    { "type": "range", "id": "desc_size_mobile", "label": "Font Size (Mobile)", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 18 },
    { "type": "select", "id": "desc_weight", "label": "Font Weight", "options": [{"value":"300","label":"Light"},{"value":"400","label":"Regular"},{"value":"600","label":"Semi-Bold"}], "default": "400" },
    { "type": "select", "id": "desc_style", "label": "Font Style", "options": [{"value":"normal","label":"Normal"},{"value":"italic","label":"Italic"}], "default": "normal" },
    { "type": "color", "id": "desc_color", "label": "Description Color", "default": "#f5f5f5" },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "btn1_label", "label": "Primary Button Label", "default": "Shop Camphor" },
    { "type": "url", "id": "btn1_link", "label": "Primary Button Link" },
    { "type": "color", "id": "btn_primary_bg", "label": "Primary Button BG", "default": "#ffffff" },
    { "type": "color", "id": "btn_primary_text", "label": "Primary Button Text", "default": "#000000" },
    { "type": "text", "id": "btn2_label", "label": "Secondary Button Label", "default": "Explore Story" },
    { "type": "url", "id": "btn2_link", "label": "Secondary Button Link" },
    { "type": "color", "id": "btn_secondary_text", "label": "Secondary Button Text", "default": "#ffffff" },
    { "type": "range", "id": "btn_radius", "label": "Button Corner Radius", "min": 0, "max": 50, "step": 2, "default": 0 },
    { "type": "header", "content": "Visual & Layout" },
    { "type": "image_picker", "id": "image", "label": "Hero Image" },
    { "type": "select", "id": "text_alignment", "label": "Text Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "range", "id": "container_width", "label": "Container Max Width", "min": 600, "max": 1400, "step": 50, "default": 1000 },
    { "type": "range", "id": "bg_brightness", "label": "Image Brightness", "min": 20, "max": 100, "step": 5, "default": 70 },
    { "type": "range", "id": "bg_blur", "label": "Image Blur", "min": 0, "max": 20, "step": 1, "default": 0 },
    { "type": "color", "id": "overlay_color", "label": "Overlay Color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay Opacity", "min": 0, "max": 100, "step": 5, "default": 30 },
    { "type": "header", "content": "Section Spacing" },
    { "type": "color", "id": "bg_color", "label": "Fallback BG Color", "default": "#ffffff" },
    { "type": "range", "id": "pt_desktop", "label": "Top Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 0 },
    { "type": "range", "id": "pb_desktop", "label": "Bottom Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 0 },
    { "type": "range", "id": "pt_mobile", "label": "Top Padding (Mobile)", "min": 0, "max": 150, "step": 5, "default": 0 },
    { "type": "range", "id": "pb_mobile", "label": "Bottom Padding (Mobile)", "min": 0, "max": 150, "step": 5, "default": 0 }
  ],
  "presets": [
    {
      "name": "HAMSAA Hero Reveal"
    }
  ]
}
{% endschema %}
