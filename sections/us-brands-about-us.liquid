{%- style -%}
  /* Section Base Styles */
  #UsBrandsAbout-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.pt_desktop }}px 0 {{ section.settings.pb_desktop }}px;
    overflow: hidden;
  }

  @media screen and (max-width: 749px) {
    #UsBrandsAbout-{{ section.id }} {
      padding: {{ section.settings.pt_mobile }}px 0 {{ section.settings.pb_mobile }}px;
    }
  }

  .us-brands-about__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    flex-direction: row;
    position: relative;
    align-items: flex-start; /* Crucial for sticky duration */
  }

  /* Split Logic */
  .us-brands-about__left {
    flex: 0 0 {{ section.settings.split_ratio }}%;
    height: auto;
    position: sticky;
    top: 25rem; /* Centered in viewport */
    padding-right: 6rem;
  }

  .us-brands-about__right {
    flex: 1;
    position: relative;
    padding-left: 6rem;
    border-left: 2px solid {{ section.settings.line_light_color }};
  }

  @media screen and (max-width: 749px) {
    .us-brands-about__container {
      flex-direction: column;
      padding: 0 2rem;
    }
    .us-brands-about__left {
      flex: 0 0 100%;
      position: relative;
      top: 0;
      padding-right: 0;
      margin-bottom: 4rem;
    }
    .us-brands-about__right {
      padding-left: 4rem;
    }
  }

  /* Left Side Content */
  .us-brands-about__left-item {
    margin-bottom: 2rem;
  }

  .us-brands-about__left-heading {
    margin: 0;
    font-size: {{ section.settings.left_heading_size }}rem;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    line-height: 1.1;
  }

  .us-brands-about__left-image {
    width: 100%;
    border-radius: 20px;
    overflow: hidden;
  }

  /* Timeline Logic */
  .us-brands-about__progress-line {
    position: absolute;
    left: -2px;
    top: 0;
    width: 2px;
    height: 0;
    background: {{ section.settings.line_active_color }};
    z-index: 2;
  }

  .us-brands-about__point {
    position: relative;
    padding-bottom: 15rem; /* Large spacing for scrollytelling */
    opacity: 0.3; /* Start grey as requested */
    transform: translateY(20px);
    transition: transform 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }

  /* Dot Style */
  .us-brands-about__dot {
    position: absolute;
    left: -6.1rem; /* Aligned with line */
    top: 0.5rem;
    transform: translateX(-50%);
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    background: {{ section.settings.line_light_color }};
    border-radius: 50%;
    z-index: 3;
    transition: background 0.4s ease, transform 0.4s ease;
  }

  .us-brands-about__point.is-active .us-brands-about__dot {
    background: {{ section.settings.line_active_color }};
    transform: translateX(-50%) scale(1.3);
  }

  .us-brands-about__point-text {
    font-size: {{ section.settings.point_size }}rem;
    font-weight: 600;
    line-height: 1.4;
    color: {{ section.settings.text_color }};
    max-width: 600px;
  }
{%- endstyle -%}

<section id="UsBrandsAbout-{{ section.id }}" class="us-brands-about">
  <div class="us-brands-about__container">
    
    <!-- Left Side: Sticky Visuals -->
    <div class="us-brands-about__left">
      {%- for block in section.blocks -%}
        {%- if block.type == 'left_heading' -%}
          <div class="us-brands-about__left-item" {{ block.shopify_attributes }}>
            <h2 class="us-brands-about__left-heading">{{ block.settings.title }}</h2>
          </div>
        {%- elsif block.type == 'left_image' -%}
          <div class="us-brands-about__left-item" {{ block.shopify_attributes }}>
            <div class="us-brands-about__left-image">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Right Side: Scrolling Story Points -->
    <div class="us-brands-about__right">
      <div class="us-brands-about__progress-line" id="ProgressLine-{{ section.id }}"></div>
      
      {%- for block in section.blocks -%}
        {%- if block.type == 'right_point' -%}
          <div class="us-brands-about__point js-about-point" {{ block.shopify_attributes }}>
            <div class="us-brands-about__dot"></div>
            <div class="us-brands-about__point-text">
              {{ block.settings.text }}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('UsBrandsAbout-{{ section.id }}');
    if (!section) return;

    const progressLine = section.querySelector('#ProgressLine-{{ section.id }}');
    const points = section.querySelectorAll('.js-about-point');
    const rightSide = section.querySelector('.us-brands-about__right');

    const updateScroll = () => {
      const rect = rightSide.getBoundingClientRect();
      const windowHeight = window.innerHeight;
      const scrollTrigger = windowHeight * 0.5; // Trigger at screen middle

      // 1. Update Progress Line Height
      const sectionStart = rect.top;
      const sectionHeight = rect.height;
      let totalProgress = 0;
      if (sectionStart < scrollTrigger) {
        totalProgress = Math.min(100, Math.max(0, ((scrollTrigger - sectionStart) / (sectionHeight - scrollTrigger)) * 100));
      }
      progressLine.style.height = totalProgress + '%';

      // 2. Update Individual Points (One-Way Reveal)
      points.forEach((point) => {
        const pointRect = point.getBoundingClientRect();
        
        // Calculate point individual progress (based on reaching middle of screen)
        const pointProgress = (windowHeight * 0.7 - pointRect.top) / (windowHeight * 0.2);
        
        // Use Math.max to ensure opacity ONLY increases (persistence)
        const currentOpacity = parseFloat(point.style.opacity) || 0.3;
        const newOpacity = Math.max(currentOpacity, Math.min(1, pointProgress));
        
        point.style.opacity = newOpacity;

        // If opacity reaches 1, keep it active (dot color)
        if (newOpacity >= 1) {
          point.classList.add('is-active');
        }

        // Translation effect
        if (newOpacity > 0.3) {
           const translateY = Math.max(0, 20 - (newOpacity - 0.3) * 50);
           point.style.transform = `translateY(${translateY}px)`;
        }
      });
    };

    window.addEventListener('scroll', updateScroll);
    window.addEventListener('resize', updateScroll);
    updateScroll(); // Initial call
  })();
</script>

{% schema %}
{
  "name": "US Brands About Us",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "range", "id": "split_ratio", "label": "Split Ratio (Left Side %)", "min": 30, "max": 70, "step": 5, "default": 40 },
    { "type": "header", "content": "Visuals" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#1a1a1a" },
    { "type": "range", "id": "left_heading_size", "label": "Left Heading Size", "min": 2, "max": 8, "step": 0.5, "unit": "rem", "default": 4.5 },
    { "type": "header", "content": "Timeline Animation" },
    { "type": "color", "id": "line_light_color", "label": "Line/Dot Inactive Color", "default": "#e5e5e5" },
    { "type": "color", "id": "line_active_color", "label": "Line/Dot Active Color", "default": "#6394FF" },
    { "type": "range", "id": "dot_size", "label": "Timeline Dot size", "min": 6, "max": 30, "step": 2, "unit": "px", "default": 16 },
    { "type": "range", "id": "point_size", "label": "Point Text Size", "min": 1, "max": 4, "step": 0.1, "unit": "rem", "default": 1.8 },
    { "type": "header", "content": "Layout Spacing" },
    { "type": "range", "id": "container_width", "label": "Container Width", "min": 1000, "max": 1600, "step": 50, "default": 1400 },
    { "type": "range", "id": "pt_desktop", "label": "Top Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 },
    { "type": "range", "id": "pb_desktop", "label": "Bottom Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 },
    { "type": "range", "id": "pt_mobile", "label": "Top Padding (Mobile)", "min": 0, "max": 100, "step": 5, "default": 50 },
    { "type": "range", "id": "pb_mobile", "label": "Bottom Padding (Mobile)", "min": 0, "max": 100, "step": 5, "default": 50 }
  ],
  "blocks": [
    {
      "type": "left_heading",
      "name": "Left Heading",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading Text", "default": "Meaning behind the brand" }
      ]
    },
    {
      "type": "left_image",
      "name": "Left Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    },
    {
      "type": "right_point",
      "name": "Story Point (Right)",
      "settings": [
        { "type": "text", "id": "text", "label": "Point Text", "default": "Inspired by the symbolism of the swan" }
      ]
    }
  ],
  "presets": [
    {
      "name": "US Brands About Us",
      "blocks": [
        { "type": "left_heading", "settings": { "title": "Meaning behind the brand" } },
        { "type": "right_point", "settings": { "text": "Inspired by the symbolism of the swan" } },
        { "type": "right_point", "settings": { "text": "A commitment to crystalline purity." } },
        { "type": "right_point", "settings": { "text": "Luxury clinical wellness at its peak." } }
      ]
    }
  ]
}
{% endschema %}
