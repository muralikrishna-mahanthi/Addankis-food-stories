{%- style -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.desc_font | font_face: font_display: 'swap' }}

  #HamsaaCatalog-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.pt_mobile }}px 0 {{ section.settings.pb_mobile }}px;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    #HamsaaCatalog-{{ section.id }} {
      padding: {{ section.settings.pt_desktop }}px 0 {{ section.settings.pb_desktop }}px;
    }
  }

  .hamsaa-catalog__header {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto 5rem;
    padding: 0 2rem;
    text-align: center;
  }

  .hamsaa-catalog__title {
    margin: 0 0 1.5rem;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s ease;
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }} !important;
    font-size: {{ section.settings.heading_size_mobile }}rem !important;
    font-weight: {{ section.settings.heading_weight }} !important;
    color: {{ section.settings.heading_color }} !important;
  }

  /* Mosaic Grid System */
  .hamsaa-catalog__grid {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media screen and (min-width: 750px) {
     .hamsaa-catalog__grid {
        grid-template-columns: repeat(12, 1fr);
        grid-auto-rows: 300px;
        gap: 2.5rem;
     }
  }

  .hamsaa-catalog__item {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.card_radius }}px;
    opacity: 0;
    transform: translateY(40px) scale(0.95);
    transition: all 1s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  /* Desktop Grid Spans */
  @media screen and (min-width: 750px) {
    .hamsaa-catalog__item:nth-child(1) { grid-column: span 8; grid-row: span 2; }
    .hamsaa-catalog__item:nth-child(2) { grid-column: span 4; grid-row: span 1; }
    .hamsaa-catalog__item:nth-child(3) { grid-column: span 4; grid-row: span 1; }
    /* ... and so on ... */
  }

  .hamsaa-catalog__item.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .hamsaa-catalog__card {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 3rem;
    color: #fff;
    z-index: 2;
  }

  .hamsaa-catalog__img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    transition: transform 1.2s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .hamsaa-catalog__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hamsaa-catalog__item:hover .hamsaa-catalog__img {
    transform: scale(1.1);
  }

  .hamsaa-catalog__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(0deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 60%);
    z-index: 1;
    transition: opacity 0.5s ease;
  }

  .hamsaa-catalog__item:hover .hamsaa-catalog__overlay {
    opacity: 0.8;
  }

  .hamsaa-catalog__card-content {
    position: relative;
    z-index: 2;
    transform: translateY(10px);
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .hamsaa-catalog__item:hover .hamsaa-catalog__card-content {
    transform: translateY(0);
  }

  .hamsaa-catalog__card-title {
    margin: 0 0 0.5rem;
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .hamsaa-catalog__card-btn {
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 500;
    opacity: 0.8;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .hamsaa-catalog__card-btn svg {
    width: 16px;
    transition: transform 0.3s ease;
  }

  .hamsaa-catalog__item:hover .hamsaa-catalog__card-btn svg {
    transform: translateX(5px);
  }

  /* Visibility Trigger */
  #HamsaaCatalog-{{ section.id }}.is-visible .hamsaa-catalog__title {
    opacity: 1;
    transform: translateY(0);
  }
{%- endstyle -%}

<section id="HamsaaCatalog-{{ section.id }}" class="hamsaa-catalog">
  <div class="hamsaa-catalog__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="hamsaa-catalog__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>

  <div class="hamsaa-catalog__grid">
    {%- for block in section.blocks -%}
      <div class="hamsaa-catalog__item hamsaa-js-stagger" style="transition-delay: {{ forloop.index0 | times: 150 }}ms;" {{ block.shopify_attributes }}>
        <div class="hamsaa-catalog__img">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {{ 'product-apparel-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="hamsaa-catalog__overlay"></div>
        <a href="{{ block.settings.link | default: '#' }}" class="hamsaa-catalog__card">
           <div class="hamsaa-catalog__card-content">
             <h3 class="hamsaa-catalog__card-title">{{ block.settings.title | default: 'Collection' }}</h3>
             <div class="hamsaa-catalog__card-btn">
               Explore Now
               <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
             </div>
           </div>
        </a>
      </div>
    {%- endfor -%}
  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('HamsaaCatalog-{{ section.id }}');
    if (!section) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
           section.classList.add('is-visible');
           section.querySelectorAll('.hamsaa-catalog__item').forEach(item => {
             item.classList.add('is-visible');
           });
        }
      });
    }, { threshold: 0.1 });

    observer.observe(section);
  })();
</script>

{% schema %}
{
  "name": "HAMSAA Product Mosaic",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "Essence of Clarity" },
    { "type": "range", "id": "container_width", "label": "Container Width", "min": 1000, "max": 1600, "step": 50, "default": 1400 },
    { "type": "header", "content": "Typography - Section Heading" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading Font", "default": "assistant_n4" },
    { "type": "range", "id": "heading_size_mobile", "label": "Font Size (Mobile)", "min": 2, "max": 6, "step": 0.5, "unit": "rem", "default": 3 },
    { "type": "select", "id": "heading_weight", "label": "Font Weight", "options": [{"value":"400","label":"Regular"},{"value":"700","label":"Bold"},{"value":"900","label":"Black"}], "default": "700" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#000000" },
    { "type": "header", "content": "Card Styling" },
    { "type": "range", "id": "card_radius", "label": "Card Corner Radius", "min": 0, "max": 50, "step": 2, "default": 0 },
    { "type": "header", "content": "Section Spacing" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "range", "id": "pt_desktop", "label": "Top Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 },
    { "type": "range", "id": "pb_desktop", "label": "Bottom Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 },
    { "type": "range", "id": "pt_mobile", "label": "Top Padding (Mobile)", "min": 0, "max": 150, "step": 5, "default": 60 },
    { "type": "range", "id": "pb_mobile", "label": "Bottom Padding (Mobile)", "min": 0, "max": 150, "step": 5, "default": 60 }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Product Category",
      "limit": 6,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Category Image" },
        { "type": "text", "id": "title", "label": "Category Name", "default": "Essential Oils" },
        { "type": "url", "id": "link", "label": "Category Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "HAMSAA Product Mosaic",
      "blocks": [
        { "type": "collection", "settings": { "title": "Essential Oils" } },
        { "type": "collection", "settings": { "title": "Wellness Balms" } },
        { "type": "collection", "settings": { "title": "Camphor Refills" } }
      ]
    }
  ]
}
{% endschema %}
