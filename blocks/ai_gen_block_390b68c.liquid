{% doc %}
  @prompt
    create section where one side should be video and another side should be text and give complete customize settings for both side and complete section settings 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.section_background_color }};
  }

  .ai-video-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.container_padding_horizontal }}px;
  }

  .ai-video-text-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap_between_columns }}px;
    align-items: {{ block.settings.vertical_alignment }};
    {% if block.settings.layout == 'video_left' %}
      flex-direction: row;
    {% else %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-video-text-video-column-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.video_column_width }}%;
    max-width: {{ block.settings.video_column_width }}%;
  }

  .ai-video-text-text-column-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.text_padding_top }}px {{ block.settings.text_padding_horizontal }}px {{ block.settings.text_padding_bottom }}px;
    background-color: {{ block.settings.text_background_color }};
    border-radius: {{ block.settings.text_border_radius }}px;
  }

  .ai-video-text-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.video_aspect_ratio }}%;
    background-color: {{ block.settings.video_background_color }};
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
  }

  .ai-video-text-video-wrapper-{{ ai_gen_id }} video,
  .ai-video-text-video-wrapper-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-text-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-text-video-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-video-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-text-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.2;
  }

  .ai-video-text-subheading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.4;
  }

  .ai-video-text-content-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.content_spacing }}px;
    font-size: {{ block.settings.content_size }}px;
    color: {{ block.settings.content_color }};
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.6;
  }

  .ai-video-text-content-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .ai-video-text-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-video-text-button-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    {% if block.settings.text_alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% else %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-video-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-video-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-video-text-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_background_color }};
    color: {{ block.settings.button_secondary_text_color }};
    border-color: {{ block.settings.button_secondary_border_color }};
  }

  .ai-video-text-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_background_color }};
    color: {{ block.settings.button_secondary_hover_text_color }};
    border-color: {{ block.settings.button_secondary_hover_border_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-video-text-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-video-text-video-column-{{ ai_gen_id }} {
      flex: 0 0 100%;
      max-width: 100%;
    }

    .ai-video-text-text-column-{{ ai_gen_id }} {
      flex: 0 0 100%;
      max-width: 100%;
    }

    .ai-video-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-video-text-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size_mobile }}px;
    }

    .ai-video-text-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_size_mobile }}px;
    }

    .ai-video-text-button-wrapper-{{ ai_gen_id }} {
      {% if block.settings.mobile_button_layout == 'stack' %}
        flex-direction: column;
      {% endif %}
    }
  }
{% endstyle %}

<video-text-section-{{ ai_gen_id }}
  class="ai-video-text-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-text-container-{{ ai_gen_id }}">
    <div class="ai-video-text-wrapper-{{ ai_gen_id }}">
      <div class="ai-video-text-video-column-{{ ai_gen_id }}">
        <div class="ai-video-text-video-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video_url != blank %}
            {% if block.settings.video_type == 'youtube' %}
              <iframe
                src="https://www.youtube.com/embed/{{ block.settings.video_url }}?autoplay={{ block.settings.video_autoplay }}&mute={{ block.settings.video_mute }}&loop={{ block.settings.video_loop }}&controls={{ block.settings.video_controls }}"
                frameborder="0"
                allow="autoplay; encrypted-media"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {% elsif block.settings.video_type == 'vimeo' %}
              <iframe
                src="https://player.vimeo.com/video/{{ block.settings.video_url }}?autoplay={{ block.settings.video_autoplay }}&muted={{ block.settings.video_mute }}&loop={{ block.settings.video_loop }}&controls={{ block.settings.video_controls }}"
                frameborder="0"
                allow="autoplay; fullscreen"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {% elsif block.settings.video_type == 'shopify' and block.settings.shopify_video != blank %}
              {{ block.settings.shopify_video | video_tag:
                autoplay: block.settings.video_autoplay,
                loop: block.settings.video_loop,
                controls: block.settings.video_controls,
                muted: block.settings.video_mute
              }}
            {% endif %}
          {% else %}
            <div class="ai-video-text-video-placeholder-{{ ai_gen_id }}">
              {{ 'collection-apparel-1' | placeholder_svg_tag }}
              <div class="ai-video-text-empty-state-{{ ai_gen_id }}">
                Next, add a video
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-video-text-text-column-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-video-text-heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.subheading != blank %}
          <div class="ai-video-text-subheading-{{ ai_gen_id }}">
            {{ block.settings.subheading }}
          </div>
        {% endif %}

        {% if block.settings.content != blank %}
          <div class="ai-video-text-content-{{ ai_gen_id }}">
            {{ block.settings.content }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank or block.settings.button_secondary_text != blank %}
          <div class="ai-video-text-button-wrapper-{{ ai_gen_id }}">
            {% if block.settings.button_text != blank %}
              <a
                href="{{ block.settings.button_link }}"
                class="ai-video-text-button-{{ ai_gen_id }}"
              >
                {{ block.settings.button_text }}
              </a>
            {% endif %}

            {% if block.settings.button_secondary_text != blank %}
              <a
                href="{{ block.settings.button_secondary_link }}"
                class="ai-video-text-button-{{ ai_gen_id }} ai-video-text-button-secondary-{{ ai_gen_id }}"
              >
                {{ block.settings.button_secondary_text }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</video-text-section-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoTextSection{{ai_gen_id}} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const videoWrapper = this.querySelector('.ai-video-text-video-wrapper-{{ ai_gen_id }}');
        if (videoWrapper) {
          const video = videoWrapper.querySelector('video');
          if (video) {
            video.addEventListener('loadedmetadata', function() {
              video.play().catch(function() {});
            });
          }
        }
      }
    }

    customElements.define('video-text-section-{{ ai_gen_id }}', VideoTextSection{{ai_gen_id}});
  })();
</script>

