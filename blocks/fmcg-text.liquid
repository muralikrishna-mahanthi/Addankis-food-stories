{%- style -%}
  .univ-anim-none { }
  .univ-anim-fade-in { animation: univFadeIn 0.8s ease forwards; opacity: 0; }
  .univ-anim-slide-up { animation: univSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; transform: translateY(30px); }
  @keyframes univFadeIn { to { opacity: 1; } }
  @keyframes univSlideUp { to { opacity: 1; transform: translateY(0); } }

  #UnivBlock-{{ block.id }} {
    width: 100%; box-sizing: border-box; text-align: {{ block.settings.alignment }};
    max-width: {{ block.settings.max_width | default: '800px' }}; margin-left: auto; margin-right: auto;
    margin-bottom: {{ block.settings.mb | default: 24 }}px;
  }
  #UnivBlock-{{ block.id }} .univ-text {
    font-size: {{ block.settings.fs_mobile }}rem;
    color: {{ block.settings.color }};
    line-height: {{ block.settings.line_height | default: 1.6 }};
    margin: 0;
  }
  @media screen and (min-width: 750px) {
    #UnivBlock-{{ block.id }} .univ-text { font-size: {{ block.settings.fs }}rem; }
  }
{%- endstyle -%}

<div id="UnivBlock-{{ block.id }}" class="univ-anim-{{ block.settings.animation | default: 'fade-in' }}" {{ block.shopify_attributes }}>
  <div class="univ-text rte">{{ block.settings.text }}</div>
</div>

{% schema %}
{
  "name": "FMCG Rich Text",
  "target": "section",
  "settings": [
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Experience uncompromising quality with our curated selection of premium ingredients.</p>" },
    { "type": "color", "id": "color", "label": "Text Color", "default": "#333333" },
    { "type": "range", "id": "fs", "label": "Desktop Size (rem)", "min": 0.5, "max": 3, "step": 0.1, "default": 1.2 },
    { "type": "range", "id": "fs_mobile", "label": "Mobile Size (rem)", "min": 0.5, "max": 2.5, "step": 0.1, "default": 1.0 },
    { "type": "text", "id": "max_width", "label": "Max Width", "default": "800px" },
    { "type": "select", "id": "alignment", "label": "Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "select", "id": "animation", "label": "Animation", "options": [{"value":"none","label":"None"},{"value":"fade-in","label":"Fade In"},{"value":"slide-up","label":"Slide Up"}], "default": "fade-in" },
    { "type": "range", "id": "mb", "label": "Margin Bottom", "min": 0, "max": 100, "step": 4, "default": 24 }
  ]
}
{% endschema %}
