{%- style -%}
  #UnivBlock-{{ block.id }} {
    width: 100%; overflow: hidden; white-space: nowrap; 
    background: {{ block.settings.bg_color }}; padding: {{ block.settings.py }}px 0; 
    border-radius: {{ block.settings.radius }}px; margin-bottom: {{ block.settings.mb | default: 24 }}px;
  }
  #UnivBlock-{{ block.id }} .univ-marquee-track { display: inline-block; animation: univMarquee {{ block.settings.speed }}s linear infinite; }
  #UnivBlock-{{ block.id }} .univ-marquee-item { 
    display: inline-block; font-size: {{ block.settings.fs }}rem; font-weight: 900; 
    color: {{ block.settings.text_color }}; margin: 0 {{ block.settings.gap }}px; text-transform: uppercase; 
  }
  @keyframes univMarquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-50%, 0, 0); } }
{%- endstyle -%}

<div id="UnivBlock-{{ block.id }}" {{ block.shopify_attributes }}>
  {%- assign items = block.settings.text | split: ',' -%}
  <div class="univ-marquee-track">
    {%- for i in (1..6) -%} {%- for item in items -%}<span class="univ-marquee-item">{{ item | strip }}</span>{%- endfor -%} {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "FMCG Marquee Banner",
  "target": "section",
  "settings": [
    { "type": "textarea", "id": "text", "label": "Marquee Text", "default": "All Natural, No GMOs, Gluten Free, Vegan Friendly", "info":"Comma separated words" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#ffffff" },
    { "type": "range", "id": "speed", "label": "Animation Speed (s)", "min": 5, "max": 60, "step": 1, "default": 20 },
    { "type": "range", "id": "fs", "label": "Font Size (rem)", "min": 1, "max": 5, "step": 0.5, "default": 2 },
    { "type": "range", "id": "gap", "label": "Gap Between Items (px)", "min": 10, "max": 100, "step": 5, "default": 40 },
    { "type": "range", "id": "py", "label": "Padding Y", "min": 0, "max": 100, "step": 4, "default": 20 },
    { "type": "range", "id": "radius", "label": "Border Radius", "min": 0, "max": 60, "step": 2, "default": 0 },
    { "type": "range", "id": "mb", "label": "Margin Bottom", "min": 0, "max": 100, "step": 4, "default": 24 }
  ]
}
{% endschema %}
