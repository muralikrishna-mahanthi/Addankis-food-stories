{%- style -%}
  .univ-anim-scale { animation: univScale 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; transform: scale(0.95); }
  @keyframes univScale { to { opacity: 1; transform: scale(1); } }

  #UnivBlock-{{ block.id }} { background-color: transparent; width: 100%; aspect-ratio: {{ block.settings.aspect_ratio | replace: ':', '/' }}; perspective: 1000px; border-radius: {{ block.settings.radius }}px; max-width: 400px; margin: 0 auto {{ block.settings.mb | default: 24 }}px; }
  #UnivBlock-{{ block.id }} .univ-flip-inner { position: relative; width: 100%; height: 100%; text-align: center; transition: transform 0.8s; transform-style: preserve-3d; border-radius: inherit;}
  #UnivBlock-{{ block.id }}:hover .univ-flip-inner { transform: rotateY(180deg); }
  #UnivBlock-{{ block.id }} .univ-flip-front, #UnivBlock-{{ block.id }} .univ-flip-back { position: absolute; width: 100%; height: 100%; -webkit-backface-visibility: hidden; backface-visibility: hidden; border-radius: inherit; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden;}
  #UnivBlock-{{ block.id }} .univ-flip-front { background-color: {{ block.settings.bg_front }}; color: {{ block.settings.color_front }}; }
  #UnivBlock-{{ block.id }} .univ-flip-front img { width: 100%; height: 100%; object-fit: cover; position: absolute; z-index: 1; }
  #UnivBlock-{{ block.id }} .univ-flip-front-content { z-index: 2; font-size: {{ block.settings.front_fs }}rem; font-weight: bold; padding: 20px; background: rgba(0,0,0,0.3); width: 100%; position: absolute; bottom: 0; backdrop-filter: blur(5px); }
  #UnivBlock-{{ block.id }} .univ-flip-back { background-color: {{ block.settings.bg_back }}; color: {{ block.settings.color_back }}; transform: rotateY(180deg); padding: 30px; text-align: left; align-items: flex-start; justify-content: center; }
  #UnivBlock-{{ block.id }} .univ-flip-title { font-size: {{ block.settings.title_fs }}rem; font-weight: 900; margin-bottom: 15px; width: 100%;}
  #UnivBlock-{{ block.id }} .univ-flip-desc { font-size: {{ block.settings.desc_fs }}rem; line-height: 1.6; }
{%- endstyle -%}

<div id="UnivBlock-{{ block.id }}" class="univ-anim-{{ block.settings.animation }}" {{ block.shopify_attributes }}>
  <div class="univ-flip-inner">
    <div class="univ-flip-front">
      {% if block.settings.image != blank %}
        {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
      {% endif %}
      <div class="univ-flip-front-content">{{ block.settings.front_title }}</div>
    </div>
    <div class="univ-flip-back">
      <div class="univ-flip-title">{{ block.settings.back_title }}</div>
      <div class="univ-flip-desc">{{ block.settings.back_text }}</div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "FMCG Ingredient Flip Card",
  "target": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Front Cover Image" },
    { "type": "text", "id": "front_title", "label": "Front Title", "default": "Almonds" },
    { "type": "text", "id": "back_title", "label": "Back Title", "default": "The Power of Almonds" },
    { "type": "textarea", "id": "back_text", "label": "Back Text", "default": "Packed with vitamin E, magnesium, and fiber, almonds offer a delicious crunch..." },
    { "type": "text", "id": "aspect_ratio", "label": "Card Aspect Ratio", "default": "3:4" },
    { "type": "color", "id": "bg_front", "label": "Front Background", "default": "#f4f4f4" },
    { "type": "color", "id": "color_front", "label": "Front Text Color", "default": "#ffffff" },
    { "type": "color", "id": "bg_back", "label": "Back Background", "default": "#3b82f6" },
    { "type": "color", "id": "color_back", "label": "Back Text Color", "default": "#ffffff" },
    { "type": "range", "id": "radius", "label": "Border Radius", "min": 0, "max": 40, "step": 2, "default": 20 },
    { "type": "range", "id": "front_fs", "label": "Front Title Size (rem)", "min": 1, "max": 4, "step": 0.2, "default": 2.0 },
    { "type": "range", "id": "title_fs", "label": "Back Title Size (rem)", "min": 1, "max": 3, "step": 0.1, "default": 1.6 },
    { "type": "range", "id": "desc_fs", "label": "Back Text Size (rem)", "min": 0.8, "max": 2, "step": 0.1, "default": 1.0 },
    { "type": "select", "id": "animation", "label": "Reveal Animation", "options": [{"value":"none","label":"None"},{"value":"scale","label":"Scale Pop"}], "default": "scale" },
    { "type": "range", "id": "mb", "label": "Margin Bottom", "min": 0, "max": 100, "step": 4, "default": 24 }
  ]
}
{% endschema %}
