{%- style -%}
  #UnivBlock-{{ block.id }} {
    width: 100%; box-sizing: border-box; text-align: {{ block.settings.alignment }};
    margin-bottom: {{ block.settings.mb | default: 24 }}px;
  }
  #UnivBlock-{{ block.id }} .univ-rw { 
    font-size: {{ block.settings.fs_mobile }}rem; font-weight: 900; 
    color: {{ block.settings.color }}; line-height: 1.2; 
  }
  @media(min-width: 750px){ #UnivBlock-{{ block.id }} .univ-rw { font-size: {{ block.settings.fs }}rem; } }
  #UnivBlock-{{ block.id }} .univ-rw-dyn { color: {{ block.settings.word_color }}; display: inline-block; position: relative; }
  #UnivBlock-{{ block.id }} .univ-rw-word { display: none; }
  #UnivBlock-{{ block.id }} .univ-rw-word.active { display: inline-block; animation: univRwPop 0.5s forwards; }
  @keyframes univRwPop { 0% { opacity: 0; transform: translateY(20px) scale(0.9); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
{%- endstyle -%}

<div id="UnivBlock-{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="univ-rw">
    <span>{{ block.settings.prefix }}</span>
    <span class="univ-rw-dyn" id="UnivRw-{{ block.id }}" data-speed="{{ block.settings.speed }}">
      {% assign words = block.settings.words | split: ',' %}
      {% for w in words %}
        <span class="univ-rw-word {% if forloop.first %}active{% endif %}">{{ w | strip }}</span>
      {% endfor %}
    </span>
    <span>{{ block.settings.suffix }}</span>
  </div>
</div>

<script>
  (function() {
    function initRotatingWords() {
      const wrap = document.getElementById('UnivRw-{{ block.id }}');
      if(!wrap) return;
      if(wrap.dataset.intervalId) clearInterval(parseInt(wrap.dataset.intervalId));
      
      const speed = parseInt(wrap.dataset.speed) || 2000;
      const words = wrap.querySelectorAll('.univ-rw-word');
      if(words.length <= 1) return;
      
      let idx = 0;
      wrap.dataset.intervalId = setInterval(() => {
        words.forEach(w => w.classList.remove('active'));
        idx = (idx + 1) % words.length;
        words[idx].classList.add('active');
      }, speed);
    }
    
    document.addEventListener('DOMContentLoaded', initRotatingWords);
    if(document.readyState !== 'loading') initRotatingWords();
    document.addEventListener('shopify:section:load', initRotatingWords);
  })();
</script>

{% schema %}
{
  "name": "FMCG Rotating Words",
  "target": "section",
  "settings": [
    { "type": "text", "id": "prefix", "label": "Static Prefix", "default": "We love to" },
    { "type": "textarea", "id": "words", "label": "Dynamic Words (comma separated)", "default": "Grow, Taste, Savor, Crunch" },
    { "type": "text", "id": "suffix", "label": "Static Suffix", "default": "together." },
    { "type": "color", "id": "color", "label": "Static Text Color", "default": "#000000" },
    { "type": "color", "id": "word_color", "label": "Dynamic Word Color", "default": "#ec4899" },
    { "type": "range", "id": "fs", "label": "Desktop Size (rem)", "min": 1, "max": 6, "step": 0.5, "default": 3 },
    { "type": "range", "id": "fs_mobile", "label": "Mobile Size (rem)", "min": 1, "max": 4, "step": 0.5, "default": 2 },
    { "type": "select", "id": "alignment", "label": "Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "range", "id": "speed", "label": "Animation Speed (ms)", "min": 500, "max": 5000, "step": 500, "default": 2000 },
    { "type": "range", "id": "mb", "label": "Margin Bottom", "min": 0, "max": 100, "step": 4, "default": 24 }
  ]
}
{% endschema %}
