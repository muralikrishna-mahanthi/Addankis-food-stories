          }
        },
        "text_block_yJTXEM": {
          "type": "text_block",
          "settings": {
            "text": "<p>Damaged or Missing Items</p>",
            "font_family": "sans_serif_n4",
            "font_size": 30,
            "font_size_mobile": 16,
            "font_weight": "700",
            "text_color": "#727272",
            "letter_spacing": 0,
