    "afspl_text_C4VJBG": {
      "type": "afspl-text",
      "blocks": {
        "text_block_6aBhr8": {
          "type": "text_block",
          "settings": {
            "text": "<p>Order Processing</p>",
            "font_family": "sans_serif_n4",
            "font_size": 30,
            "font_size_mobile": 16,
            "font_weight": "700",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_JpcBrh": {
          "type": "text_block",
          "settings": {
            "text": "<ul><li>All orders are processed within <strong>1–3 business days</strong> after confirmation.</li><li>Orders placed on weekends or public holidays will be processed on the next working day.</li><li>You will receive an <strong>order confirmation</strong> and <strong>dispatch notification</strong> via email/SMS.</li></ul>",
            "font_family": "sans_serif_n4",
            "font_size": 20,
            "font_size_mobile": 16,
            "font_weight": "500",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_ifkkE3": {
          "type": "text_block",
          "settings": {
            "text": "<p>Shipping Timeline</p>",
            "font_family": "sans_serif_n4",
            "font_size": 30,
            "font_size_mobile": 16,
            "font_weight": "700",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_mG64Bn": {
          "type": "text_block",
          "settings": {
            "text": "<ul><li><strong>Standard Delivery:</strong> 3–7 business days</li><li><strong>Remote Areas:</strong> 5–10 business days<br/></li></ul><p>Delivery timelines may vary depending on location, courier availability, and unforeseen circumstances.</p>",
            "font_family": "sans_serif_n4",
            "font_size": 20,
            "font_size_mobile": 16,
            "font_weight": "500",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_yG8tYa": {
          "type": "text_block",
          "settings": {
            "text": "<p>Shipping Charges</p>",
            "font_family": "sans_serif_n4",
            "font_size": 30,
            "font_size_mobile": 16,
            "font_weight": "700",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_nrde9Q": {
          "type": "text_block",
          "settings": {
            "text": "<ul><li>Shipping charges are calculated at checkout based on your location and order value.</li><li>We may offer <strong>free shipping</strong> on select orders or promotional campaigns.</li></ul>",
            "font_family": "sans_serif_n4",
            "font_size": 20,
            "font_size_mobile": 16,
            "font_weight": "500",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_GKzd9y": {
          "type": "text_block",
          "settings": {
            "text": "<p>Order Tracking</p>",
            "font_family": "sans_serif_n4",
            "font_size": 30,
            "font_size_mobile": 16,
            "font_weight": "700",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_DULtPw": {
          "type": "text_block",
          "settings": {
            "text": "<ul><li>Once your order is shipped, you will receive a <strong>tracking ID/link</strong> to monitor delivery status in real time.</li></ul>",
            "font_family": "sans_serif_n4",
            "font_size": 20,
            "font_size_mobile": 16,
            "font_weight": "500",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_FeE6CD": {
          "type": "text_block",
          "settings": {
            "text": "<p>Delivery Partners</p>",
            "font_family": "sans_serif_n4",
            "font_size": 30,
            "font_size_mobile": 16,
            "font_weight": "700",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_npCPV8": {
          "type": "text_block",
          "settings": {
            "text": "<p>We work with reliable courier partners to ensure timely and safe delivery of your products.</p>",
            "font_family": "sans_serif_n4",
            "font_size": 20,
            "font_size_mobile": 16,
            "font_weight": "500",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_YC7AHM": {
          "type": "text_block",
          "settings": {
            "text": "<p>Delays & Exceptions</p>",
            "font_family": "sans_serif_n4",
            "font_size": 30,
            "font_size_mobile": 16,
            "font_weight": "700",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_B8TF7H": {
          "type": "text_block",
          "settings": {
            "text": "<p>While we strive to deliver on time, delays may occur due to:</p><ul><li>Weather conditions</li><li>Logistics issues</li><li>High order volumes</li><li>Government restrictions or unforeseen events</li></ul><p>We appreciate your patience in such cases.</p>",
            "font_family": "sans_serif_n4",
            "font_size": 20,
            "font_size_mobile": 16,
            "font_weight": "500",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_YqKRpL": {
          "type": "text_block",
          "settings": {
            "text": "<p>Incorrect Address / Failed Delivery</p>",
            "font_family": "sans_serif_n4",
            "font_size": 30,
            "font_size_mobile": 16,
            "font_weight": "700",
            "text_color": "#727272",
            "letter_spacing": 0,
            "word_spacing": 1,
            "text_alignment": "left",
            "margin_bottom": 30
          }
        },
        "text_block_3JYRLE": {
          "type": "text_block",
          "settings": {
            "text": "<ul><li>Please ensure your shipping details are accurate.</li><li>If delivery fails due to incorrect address or unavailability, re-shipping charges may apply.</li></ul>",
            "font_family": "sans_serif_n4",
            "font_size": 20,
            "font_size_mobile": 16,
            "font_weight": "500",
            "text_color": "#727272",
            "letter_spacing": 0,
