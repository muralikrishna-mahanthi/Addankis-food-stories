        "text_block_DXbmzi": {
          "type": "text_block",
          "settings": {
            "text": "<p>Nithish Reddy serves as the Chief Financial Officer (CFO) of Addanki’s Food Stories Pvt. Ltd., overseeing the company’s financial strategy, capital planning, and financial governance as the organization expands its FMCG brands and distribution platform.</p>",
            "font_family": "arimo_n4",
            "font_size": 22,
            "font_size_mobile": 16,
