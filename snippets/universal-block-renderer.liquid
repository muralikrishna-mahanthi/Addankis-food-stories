{%- comment -%}
  Universal FMCG Block Renderer
  Renders diverse blocks with custom sizing, colors, and animations.
{%- endcomment -%}

{%- if global_univ_css == blank -%}
<style>
  .univ-block { position: relative; box-sizing: border-box; width: 100%; }
  .univ-block-align-left { text-align: left; justify-content: flex-start; align-items: flex-start; }
  .univ-block-align-center { text-align: center; justify-content: center; align-items: center; }
  .univ-block-align-right { text-align: right; justify-content: flex-end; align-items: flex-end; }
  
  /* Shared Animations */
  .univ-anim-none { }
  .univ-anim-fade-in { animation: univFadeIn 0.8s ease forwards; opacity: 0; }
  .univ-anim-slide-up { animation: univSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; transform: translateY(30px); }
  .univ-anim-scale { animation: univScale 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; transform: scale(0.95); }
  
  @keyframes univFadeIn { to { opacity: 1; } }
  @keyframes univSlideUp { to { opacity: 1; transform: translateY(0); } }
  @keyframes univScale { to { opacity: 1; transform: scale(1); } }
</style>
{%- assign global_univ_css = true -%}
{%- endif -%}

{%- style -%}
  #UnivBlock-{{ block.id }} {
    margin-top: {{ block.settings.mt_mobile | default: 0 }}px;
    margin-bottom: {{ block.settings.mb_mobile | default: 16 }}px;
    padding-top: {{ block.settings.pt_mobile | default: 0 }}px;
    padding-bottom: {{ block.settings.pb_mobile | default: 0 }}px;
    padding-left: {{ block.settings.px_mobile | default: 0 }}px;
    padding-right: {{ block.settings.px_mobile | default: 0 }}px;
    max-width: {{ block.settings.max_width | default: '100%' }};
    margin-left: auto; margin-right: auto;
  }
  @media screen and (min-width: 750px) {
    #UnivBlock-{{ block.id }} {
      margin-top: {{ block.settings.mt | default: 0 }}px;
      margin-bottom: {{ block.settings.mb | default: 24 }}px;
      padding-top: {{ block.settings.pt | default: 0 }}px;
      padding-bottom: {{ block.settings.pb | default: 0 }}px;
      padding-left: {{ block.settings.px | default: 0 }}px;
      padding-right: {{ block.settings.px | default: 0 }}px;
      {% if block.settings.max_width != '100%' %}max-width: {{ block.settings.max_width }};{% endif %}
    }
  }

  {%- if block.type == 'fmcg_heading' -%}
    #UnivBlock-{{ block.id }} .univ-heading {
      font-size: {{ block.settings.fs_mobile }}rem;
      color: {{ block.settings.color }};
      font-weight: {{ block.settings.weight }};
      line-height: {{ block.settings.line_height }};
      letter-spacing: {{ block.settings.letter_spacing }}px;
      text-transform: {{ block.settings.text_transform }};
      margin: 0;
    }
    {%- if block.settings.use_gradient -%}
    #UnivBlock-{{ block.id }} .univ-heading {
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_start }}, {{ block.settings.gradient_end }});
      background-clip: text; -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: inline-block;
    }
    {%- endif -%}
    @media screen and (min-width: 750px) {
      #UnivBlock-{{ block.id }} .univ-heading { font-size: {{ block.settings.fs }}rem; }
    }
  {%- endif -%}

  {%- if block.type == 'fmcg_text' -%}
    #UnivBlock-{{ block.id }} .univ-text {
      font-size: {{ block.settings.fs_mobile }}rem;
      color: {{ block.settings.color }};
      line-height: {{ block.settings.line_height }};
    }
    @media screen and (min-width: 750px) { #UnivBlock-{{ block.id }} .univ-text { font-size: {{ block.settings.fs }}rem; } }
  {%- endif -%}
{%- endstyle -%}

<div id="UnivBlock-{{ block.id }}" class="univ-block univ-block--{{ block.type }} univ-block-align-{{ block.settings.alignment | default: 'center' }} univ-anim-{{ block.settings.animation | default: 'none' }}" {{ block.shopify_attributes }}>
  
  {%- case block.type -%}
    
    {%- when 'fmcg_heading' -%}
      <{{ block.settings.html_tag | default: 'h2' }} class="univ-heading">
        {{ block.settings.title }}
      </{{ block.settings.html_tag | default: 'h2' }}>

    {%- when 'fmcg_text' -%}
      <div class="univ-text rte">{{ block.settings.text }}</div>

    {%- when 'fmcg_button_group' -%}
      <style>
        #UnivBlock-{{ block.id }} .univ-buttons { display: flex; gap: {{ block.settings.gap }}px; flex-wrap: wrap; justify-content: {% if block.settings.alignment == 'left' %}flex-start{% elsif block.settings.alignment == 'right' %}flex-end{% else %}center{% endif %}; }
        {%- for i in (1..2) -%}
          {%- assign show_key = 'btn_' | append: i | append: '_show' -%}
          {%- if block.settings[show_key] -%}
            {%- assign bg = 'btn_' | append: i | append: '_bg' -%}
            {%- assign color = 'btn_' | append: i | append: '_color' -%}
            {%- assign border = 'btn_' | append: i | append: '_border' -%}
            {%- assign hover_bg = 'btn_' | append: i | append: '_hover_bg' -%}
            {%- assign hover_color = 'btn_' | append: i | append: '_hover_color' -%}
            .univ-btn-{{ block.id }}-{{ i }} { display: inline-flex; align-items: center; justify-content: center; text-decoration: none; padding: {{ block.settings.py }}px {{ block.settings.px }}px; border-radius: {{ block.settings.radius }}px; font-weight: bold; font-size: {{ block.settings.fs }}rem; text-transform: uppercase; background: {{ block.settings[bg] }}; color: {{ block.settings[color] }}; border: 2px solid {{ block.settings[border] }}; transition: all 0.3s ease; }
            .univ-btn-{{ block.id }}-{{ i }}:hover { background: {{ block.settings[hover_bg] }}; color: {{ block.settings[hover_color] }}; transform: translateY(-3px); box-shadow: 0 8px 15px rgba(0,0,0,0.15); }
          {%- endif -%}
        {%- endfor -%}
      </style>
      <div class="univ-buttons">
        {%- if block.settings.btn_1_show -%}<a href="{{ block.settings.btn_1_link }}" class="univ-btn-{{ block.id }}-1">{{ block.settings.btn_1_label }}</a>{%- endif -%}
        {%- if block.settings.btn_2_show -%}<a href="{{ block.settings.btn_2_link }}" class="univ-btn-{{ block.id }}-2">{{ block.settings.btn_2_label }}</a>{%- endif -%}
      </div>

    {%- when 'fmcg_image' -%}
      <div style="border-radius: {{ block.settings.radius }}px; overflow: hidden; box-shadow: 0 {{ block.settings.shadow }}px {{ block.settings.shadow | times: 2 }}px rgba(0,0,0,0.15);">
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 2000 | image_tag: style: 'width: 100%; height: auto; display: block;', loading: 'lazy' }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

    {%- when 'fmcg_video' -%}
      <div style="border-radius: {{ block.settings.radius }}px; overflow: hidden; aspect-ratio: {{ block.settings.aspect_ratio | replace: ':', '/' }}; box-shadow: 0 {{ block.settings.shadow }}px {{ block.settings.shadow | times: 2 }}px rgba(0,0,0,0.15);">
        {%- if block.settings.video != blank -%}
          {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '2000x', style: 'width: 100%; height: 100%; object-fit: cover;' }}
        {%- else -%}
          <div style="width: 100%; height: 100%; background: #ccc;">No Video Selected</div>
        {%- endif -%}
      </div>

    {%- when 'fmcg_marquee' -%}
      <style>
        #UnivBlock-{{ block.id }} .univ-marquee-wrap { overflow: hidden; white-space: nowrap; width: 100%; background: {{ block.settings.bg_color }}; padding: {{ block.settings.py }}px 0; border-radius: {{ block.settings.radius }}px; }
        #UnivBlock-{{ block.id }} .univ-marquee-track { display: inline-block; animation: univMarquee {{ block.settings.speed }}s linear infinite; }
        #UnivBlock-{{ block.id }} .univ-marquee-item { display: inline-block; font-size: {{ block.settings.fs }}rem; font-weight: 900; color: {{ block.settings.text_color }}; margin: 0 {{ block.settings.gap }}px; text-transform: uppercase; }
        @keyframes univMarquee { 0% { transform: translate3d(0, 0, 0); } 100% { transform: translate3d(-50%, 0, 0); } }
      </style>
      {%- assign items = block.settings.text | split: ',' -%}
      <div class="univ-marquee-wrap">
        <div class="univ-marquee-track">
          {%- for i in (1..6) -%} {%- for item in items -%}<span class="univ-marquee-item">{{ item | strip }}</span>{%- endfor -%} {%- endfor -%}
        </div>
      </div>

    {%- when 'fmcg_icon_with_text' -%}
      <style>
        .univ-icon-text-{{ block.id }} { display: flex; align-items: {% if block.settings.layout == 'column' %}center{% else %}flex-start{% endif %}; gap: {{ block.settings.gap }}px; flex-direction: {{ block.settings.layout }}; }
        .univ-icon-{{ block.id }} { flex-shrink: 0; width: {{ block.settings.icon_size }}px; height: {{ block.settings.icon_size }}px; border-radius: {{ block.settings.icon_radius }}px; background: {{ block.settings.icon_bg }}; display: flex; align-items: center; justify-content: center; color: {{ block.settings.icon_color }}; overflow:hidden; }
        .univ-icon-text-content-{{ block.id }} { text-align: {% if block.settings.layout == 'column' %}center{% else %}left{% endif %}; }
        .univ-icon-title-{{ block.id }} { font-size: {{ block.settings.title_fs }}rem; font-weight: bold; color: {{ block.settings.title_color }}; margin-bottom: 4px; line-height: 1.2; }
        .univ-icon-desc-{{ block.id }} { font-size: {{ block.settings.desc_fs }}rem; color: {{ block.settings.desc_color }}; line-height: 1.5; margin:0;}
      </style>
      <div class="univ-icon-text-{{ block.id }}">
        <div class="univ-icon-{{ block.id }}">
           {% if block.settings.image != blank %}
             <img src="{{ block.settings.image | image_url: width: 200 }}" style="width:100%; height:100%; object-fit:cover;" loading="lazy">
           {% elsif block.settings.svg_code != blank %}
             <div style="width:{{ block.settings.icon_size | times: 0.6 }}px; height:{{ block.settings.icon_size | times: 0.6 }}px; display:flex;">{{ block.settings.svg_code }}</div>
           {% endif %}
        </div>
        <div class="univ-icon-text-content-{{ block.id }}">
           {% if block.settings.title != blank %}<div class="univ-icon-title-{{ block.id }}">{{ block.settings.title }}</div>{% endif %}
           {% if block.settings.text != blank %}<div class="univ-icon-desc-{{ block.id }}">{{ block.settings.text }}</div>{% endif %}
        </div>
      </div>

    {%- when 'fmcg_ingredient_card' -%}
      <style>
        .univ-flip-{{ block.id }} { background-color: transparent; width: 100%; aspect-ratio: {{ block.settings.aspect_ratio | replace: ':', '/' }}; perspective: 1000px; border-radius: {{ block.settings.radius }}px; max-width: 400px; margin: 0 auto; }
        .univ-flip-inner-{{ block.id }} { position: relative; width: 100%; height: 100%; text-align: center; transition: transform 0.8s; transform-style: preserve-3d; border-radius: inherit;}
        .univ-flip-{{ block.id }}:hover .univ-flip-inner-{{ block.id }} { transform: rotateY(180deg); }
        .univ-flip-front-{{ block.id }}, .univ-flip-back-{{ block.id }} { position: absolute; width: 100%; height: 100%; -webkit-backface-visibility: hidden; backface-visibility: hidden; border-radius: inherit; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden;}
        .univ-flip-front-{{ block.id }} { background-color: {{ block.settings.bg_front }}; color: {{ block.settings.color_front }}; }
        .univ-flip-front-{{ block.id }} img { width: 100%; height: 100%; object-fit: cover; position: absolute; z-index: 1; }
        .univ-flip-front-content-{{ block.id }} { z-index: 2; font-size: {{ block.settings.front_fs }}rem; font-weight: bold; padding: 20px; background: rgba(0,0,0,0.3); width: 100%; position: absolute; bottom: 0; backdrop-filter: blur(5px); }
        .univ-flip-back-{{ block.id }} { background-color: {{ block.settings.bg_back }}; color: {{ block.settings.color_back }}; transform: rotateY(180deg); padding: 30px; text-align: left; align-items: flex-start; justify-content: center; }
        .univ-flip-title-{{ block.id }} { font-size: {{ block.settings.title_fs }}rem; font-weight: 900; margin-bottom: 15px; }
        .univ-flip-desc-{{ block.id }} { font-size: {{ block.settings.desc_fs }}rem; line-height: 1.6; }
      </style>
      <div class="univ-flip-{{ block.id }}">
        <div class="univ-flip-inner-{{ block.id }}">
          <div class="univ-flip-front-{{ block.id }}">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {% endif %}
            <div class="univ-flip-front-content-{{ block.id }}">{{ block.settings.front_title }}</div>
          </div>
          <div class="univ-flip-back-{{ block.id }}">
            <div class="univ-flip-title-{{ block.id }}">{{ block.settings.back_title }}</div>
            <div class="univ-flip-desc-{{ block.id }}">{{ block.settings.back_text }}</div>
          </div>
        </div>
      </div>

    {%- when 'fmcg_rotating_words' -%}
       <style>
         #UnivBlock-{{ block.id }} .univ-rw { font-size: {{ block.settings.fs_mobile }}rem; font-weight: 900; color: {{ block.settings.color }}; line-height: 1.2; text-align: {{ block.settings.alignment }}; }
         @media(min-width: 750px){ #UnivBlock-{{ block.id }} .univ-rw { font-size: {{ block.settings.fs }}rem; } }
         #UnivBlock-{{ block.id }} .univ-rw-dyn { color: {{ block.settings.word_color }}; display: inline-block; position: relative; }
         #UnivBlock-{{ block.id }} .univ-rw-word { display: none; }
         #UnivBlock-{{ block.id }} .univ-rw-word.active { display: inline-block; animation: univRwPop 0.5s forwards; }
         @keyframes univRwPop { 0% { opacity: 0; transform: translateY(20px) scale(0.9); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
       </style>
       <div class="univ-rw">
         <span>{{ block.settings.prefix }}</span>
         <span class="univ-rw-dyn" id="UnivRw-{{ block.id }}" data-speed="{{ block.settings.speed }}">
           {% assign words = block.settings.words | split: ',' %}
           {% for w in words %}
             <span class="univ-rw-word {% if forloop.first %}active{% endif %}">{{ w | strip }}</span>
           {% endfor %}
         </span>
         <span>{{ block.settings.suffix }}</span>
       </div>
       <script>
         document.addEventListener('DOMContentLoaded', () => {
           setInterval(() => {
             const wrap = document.getElementById('UnivRw-{{ block.id }}');
             if(!wrap) return;
             const words = wrap.querySelectorAll('.univ-rw-word');
             if(words.length <= 1) return;
             let activeIdx = Array.from(words).findIndex(w => w.classList.contains('active'));
             if(activeIdx === -1) activeIdx = 0;
             words[activeIdx].classList.remove('active');
             words[(activeIdx + 1) % words.length].classList.add('active');
           }, {{ block.settings.speed | default: 2000 }});
         });
       </script>

    {%- when 'fmcg_quote' -%}
      <style>
        #UnivBlock-{{ block.id }} .univ-quote { text-align: {{ block.settings.alignment }}; padding: {{ block.settings.py }}px {{ block.settings.px }}px; background: {{ block.settings.bg_color }}; border-radius: {{ block.settings.radius }}px; position: relative; overflow:hidden;}
        #UnivBlock-{{ block.id }} .univ-quote::before { content: '"'; font-family: serif; font-size: 8rem; position: absolute; top: -10px; left: 20px; opacity: 0.1; line-height: 1; color: {{ block.settings.text_color }}; }
        #UnivBlock-{{ block.id }} .univ-quote-text { font-size: {{ block.settings.fs }}rem; color: {{ block.settings.text_color }}; font-style: italic; font-weight: 500; line-height: 1.4; position: relative; z-index: 2; margin-bottom: 20px; }
        #UnivBlock-{{ block.id }} .univ-quote-author { font-size: {{ block.settings.author_fs }}rem; color: {{ block.settings.author_color }}; font-weight: 800; text-transform: uppercase; letter-spacing: 2px;}
      </style>
      <div class="univ-quote">
        <div class="univ-quote-text">{{ block.settings.text }}</div>
        <div class="univ-quote-author">- {{ block.settings.author }}</div>
      </div>

    {%- when 'fmcg_spacer' -%}
      <style>
        .univ-spacer-desktop-{{ block.id }} { display: none; }
        .univ-spacer-mobile-{{ block.id }} { height: {{ block.settings.height_mobile }}px; width: 100%; display:block;}
        @media (min-width: 750px) {
          .univ-spacer-mobile-{{ block.id }} { display: none; }
          .univ-spacer-desktop-{{ block.id }} { display: block; height: {{ block.settings.height }}px; width: 100%;}
        }
      </style>
      <div class="univ-spacer-mobile-{{ block.id }}"></div>
      <div class="univ-spacer-desktop-{{ block.id }}"></div>

  {%- endcase -%}
</div>
