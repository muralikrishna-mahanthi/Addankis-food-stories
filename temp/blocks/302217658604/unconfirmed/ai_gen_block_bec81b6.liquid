    {
      "type": "range",
      "id": "text_scroll_speed",
      "min": 0,
      "max": 2,
      "step": 0.1,
      "label": "Text scroll speed",
      "default": 0.2
    }
  ],
  "presets": [
    {
      "name": "Parallax hero"
    }
  ]
}
{% endschema %}
