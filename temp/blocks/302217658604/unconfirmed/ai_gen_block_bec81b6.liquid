{% doc %}
  @prompt
    create a hero section for image and heading on that image and make the heading on that image should be center below and give customize settings of padding for heading as full size on image and make it animate like while scrolling the bar image should move fast and text should move slowly to top, give font family and font weight to bolder max for heading and size of heading settings also
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-parallax-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.hero_height }}px;
    overflow: hidden;
    display: block;
  }

  .ai-parallax-hero__image-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 120%;
    will-change: transform;
  }

  .ai-parallax-hero__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-parallax-hero__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-parallax-hero__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-parallax-hero__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-parallax-hero__content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: {{ block.settings.heading_padding_top }}px {{ block.settings.heading_padding_horizontal }}px {{ block.settings.heading_padding_bottom }}px {{ block.settings.heading_padding_horizontal }}px;
    display: flex;
    justify-content: center;
    align-items: center;
    will-change: transform;
  }

  .ai-parallax-hero__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: center;
    margin: 0;
    text-shadow: {{ block.settings.text_shadow_horizontal }}px {{ block.settings.text_shadow_vertical }}px {{ block.settings.text_shadow_blur }}px {{ block.settings.text_shadow_color }};
    background-color: {{ block.settings.heading_background_color }};
    padding: {{ block.settings.heading_inner_padding }}px;
    border-radius: {{ block.settings.heading_border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-parallax-hero-{{ ai_gen_id }} {
      height: {{ block.settings.hero_height | times: 0.7 }}px;
    }

    .ai-parallax-hero__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-parallax-hero__content-{{ ai_gen_id }} {
      padding: {{ block.settings.heading_padding_top | times: 0.7 }}px {{ block.settings.heading_padding_horizontal | times: 0.7 }}px {{ block.settings.heading_padding_bottom | times: 0.7 }}px {{ block.settings.heading_padding_horizontal | times: 0.7 }}px;
    }
  }
{% endstyle %}

<parallax-hero-{{ ai_gen_id }}
  class="ai-parallax-hero-{{ ai_gen_id }}"
  data-image-speed="{{ block.settings.image_scroll_speed }}"
  data-text-speed="{{ block.settings.text_scroll_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-parallax-hero__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.hero_image %}
      <img
        src="{{ block.settings.hero_image | image_url: width: 2000 }}"
        alt="{{ block.settings.hero_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.hero_image.width }}"
        height="{{ block.settings.hero_image.height }}"
        class="ai-parallax-hero__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-parallax-hero__image-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-parallax-hero__empty-state-{{ ai_gen_id }}">
          Add an image to get started
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-parallax-hero__content-{{ ai_gen_id }}">
    <h1 class="ai-parallax-hero__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h1>
  </div>
</parallax-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class ParallaxHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.imageWrapper = this.querySelector('.ai-parallax-hero__image-wrapper-{{ ai_gen_id }}');
        this.content = this.querySelector('.ai-parallax-hero__content-{{ ai_gen_id }}');
        this.imageSpeed = parseFloat(this.dataset.imageSpeed);
        this.textSpeed = parseFloat(this.dataset.textSpeed);
        this.handleScroll = this.handleScroll.bind(this);
      }

      connectedCallback() {
        window.addEventListener('scroll', this.handleScroll);
        this.handleScroll();
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll);
      }

      handleScroll() {
        const rect = this.getBoundingClientRect();
        const scrollPercent = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);

        if (scrollPercent >= 0 && scrollPercent <= 1) {
          const imageOffset = scrollPercent * 100 * this.imageSpeed;
          const textOffset = scrollPercent * 100 * this.textSpeed;

          if (this.imageWrapper) {
            this.imageWrapper.style.transform = `translateY(-${imageOffset}px)`;
          }

          if (this.content) {
            this.content.style.transform = `translateY(-${textOffset}px)`;
          }
        }
      }
    }

    customElements.define('parallax-hero-{{ ai_gen_id }}', ParallaxHero{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Parallax hero",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 300,
      "max": 900,
      "step": 50,
      "unit": "px",
      "label": "Height",
      "default": 600
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading text",
      "default": "Welcome to our store"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
