    {
      "type": "color",
      "id": "heading_background_color",
      "label": "Heading background",
      "default": "rgba(0,0,0,0.0)"
    },
    {
      "type": "range",
      "id": "heading_inner_padding",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Heading inner padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "heading_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Heading position"
    },
    {
      "type": "range",
      "id": "heading_padding_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_padding_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_padding_horizontal",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 40
    },
    {
      "type": "header",
      "content": "Text shadow"
    },
    {
      "type": "range",
      "id": "text_shadow_horizontal",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Horizontal offset",
      "default": 0
    },
    {
      "type": "range",
      "id": "text_shadow_vertical",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Vertical offset",
      "default": 2
    },
    {
      "type": "range",
      "id": "text_shadow_blur",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Blur",
      "default": 4
    },
    {
      "type": "color",
      "id": "text_shadow_color",
      "label": "Shadow color",
      "default": "rgba(0,0,0,0.5)"
    },
    {
      "type": "header",
      "content": "Parallax effect"
    },
    {
      "type": "range",
      "id": "image_scroll_speed",
      "min": 0,
      "max": 2,
