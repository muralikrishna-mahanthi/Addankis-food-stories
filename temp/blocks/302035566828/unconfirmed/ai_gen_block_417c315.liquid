{% doc %}
  @prompt
    create a section like showing my 4 brands with icons and texts and make it with more animations while touching while hovering while moving the scroll bar and all for the section make the 4 brands customize by me and give all customizable settings for me so that i can customize all
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brands-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-brands-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-brands-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ai-brands-header-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-brands-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: {{ block.settings.title_weight }};
  }

  .ai-brands-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-brands-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_top_spacing }}px;
  }

  .ai-brand-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateY(50px) scale(0.9);
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-brand-item-{{ ai_gen_id }}.ai-visible-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .ai-brand-item-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px) scale({{ block.settings.hover_scale }});
    box-shadow: {{ block.settings.hover_shadow_x }}px {{ block.settings.hover_shadow_y }}px {{ block.settings.hover_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.hover_shadow_opacity }});
    background-color: {{ block.settings.card_hover_background }};
  }

  .ai-brand-item-{{ ai_gen_id }}:active {
    transform: translateY(-{{ block.settings.hover_lift | divided_by: 2 }}px) scale({{ block.settings.hover_scale | minus: 0.02 }});
  }

  .ai-brand-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-brand-item-{{ ai_gen_id }}:hover .ai-brand-icon-wrapper-{{ ai_gen_id }} {
    transform: rotate({{ block.settings.icon_rotate }}deg) scale({{ block.settings.icon_hover_scale }});
  }

  .ai-brand-icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-brand-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.icon_placeholder_bg }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-brand-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-brand-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_name_size }}px;
    color: {{ block.settings.brand_name_color }};
    margin: 0 0 {{ block.settings.brand_name_spacing }}px;
    font-weight: {{ block.settings.brand_name_weight }};
    transition: color 0.3s ease;
  }

  .ai-brand-item-{{ ai_gen_id }}:hover .ai-brand-name-{{ ai_gen_id }} {
    color: {{ block.settings.brand_name_hover_color }};
  }

  .ai-brand-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_description_size }}px;
    color: {{ block.settings.brand_description_color }};
    line-height: 1.5;
    margin: 0;
    transition: color 0.3s ease;
  }

  .ai-brand-item-{{ ai_gen_id }}:hover .ai-brand-description-{{ ai_gen_id }} {
    color: {{ block.settings.brand_description_hover_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-brands-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-brands-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-brands-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-brands-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-brand-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<brands-showcase-{{ ai_gen_id }} class="ai-brands-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brands-container-{{ ai_gen_id }}">
    {% if block.settings.section_title != blank or block.settings.section_subtitle != blank %}
      <div class="ai-brands-header-{{ ai_gen_id }}" data-animate>
        {% if block.settings.section_title != blank %}
          <h2 class="ai-brands-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
        {% endif %}
        {% if block.settings.section_subtitle != blank %}
          <p class="ai-brands-subtitle-{{ ai_gen_id }}">{{ block.settings.section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-brands-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign brand_name_key = 'brand_' | append: i | append: '_name'
          assign brand_description_key = 'brand_' | append: i | append: '_description'
          assign brand_icon_key = 'brand_' | append: i | append: '_icon'
          
          assign brand_name = block.settings[brand_name_key]
          assign brand_description = block.settings[brand_description_key]
          assign brand_icon = block.settings[brand_icon_key]
        %}

        <div class="ai-brand-item-{{ ai_gen_id }}" data-animate data-delay="{{ forloop.index | times: 100 }}">
          <div class="ai-brand-icon-wrapper-{{ ai_gen_id }}">
            {% if brand_icon %}
              <img
                src="{{ brand_icon | image_url: width: 400 }}"
                alt="{{ brand_name | escape }}"
                loading="lazy"
                width="400"
                height="400"
              >
            {% else %}
              <div class="ai-brand-icon-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          {% if brand_name != blank %}
            <h3 class="ai-brand-name-{{ ai_gen_id }}">{{ brand_name }}</h3>
          {% endif %}

          {% if brand_description != blank %}
            <p class="ai-brand-description-{{ ai_gen_id }}">{{ brand_description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</brands-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class BrandsShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.animatedElements = [];
        this.observer = null;
      }

      connectedCallback() {
        this.setupScrollAnimations();
        this.setupTouchAnimations();
      }

      setupScrollAnimations() {
        this.animatedElements = this.querySelectorAll('[data-animate]');
        
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const delay = entry.target.dataset.delay || 0;
              setTimeout(() => {
                entry.target.classList.add('ai-visible-{{ ai_gen_id }}');
              }, delay);
              this.observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        this.animatedElements.forEach(element => {
          this.observer.observe(element);
        });
      }

      setupTouchAnimations() {
        const brandItems = this.querySelectorAll('.ai-brand-item-{{ ai_gen_id }}');
        
        brandItems.forEach(item => {
          item.addEventListener('touchstart', () => {
            item.style.transform = 'translateY(-{{ block.settings.hover_lift | divided_by: 2 }}px) scale({{ block.settings.hover_scale | minus: 0.02 }})';
          });

          item.addEventListener('touchend', () => {
            item.style.transform = '';
          });

          item.addEventListener('touchcancel', () => {
            item.style.transform = '';
          });
        });
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('brands-showcase-{{ ai_gen_id }}', BrandsShowcase{{ ai_gen_id }});
  })();
</script>

