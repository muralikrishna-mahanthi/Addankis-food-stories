{% doc %}
  @prompt
    create a hero section for image and heading on that image and make the heading on that image should be center below and give customize settings of padding for heading as full size on image and make it animate like while scrolling the bar image should move fast and text should move slowly to top, give font family and font weight to bolder max for heading and size of heading settings also, GIVE font weight settings like light, bold, bolder, and extra large bold settings and make the image move inside the given screen size and don't make background color backside of image after image is moving to top
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-parallax-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.hero_height }}vh;
    overflow: hidden;
    display: block;
  }

  .ai-parallax-hero__image-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    will-change: transform;
  }

  .ai-parallax-hero__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-parallax-hero__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-parallax-hero__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-parallax-hero__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-parallax-hero__content-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.heading_padding_bottom }}%;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 20px;
    will-change: transform;
    z-index: 2;
  }

  .ai-parallax-hero__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    text-align: center;
    margin: 0;
    text-shadow: {{ block.settings.text_shadow_horizontal }}px {{ block.settings.text_shadow_vertical }}px {{ block.settings.text_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.text_shadow_opacity }});
    max-width: 100%;
    word-wrap: break-word;
  }

  @media screen and (max-width: 749px) {
    .ai-parallax-hero__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.6);
    }

    .ai-parallax-hero-{{ ai_gen_id }} {
      height: {{ block.settings.hero_height | times: 0.7 }}vh;
    }
  }
{% endstyle %}

<parallax-hero-{{ ai_gen_id }}
  class="ai-parallax-hero-{{ ai_gen_id }}"
  data-parallax-speed="{{ block.settings.parallax_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-parallax-hero__image-wrapper-{{ ai_gen_id }}" data-parallax-image>
    {% if block.settings.hero_image %}
      <img
        src="{{ block.settings.hero_image | image_url: width: 2000 }}"
        alt="{{ block.settings.hero_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.hero_image.width }}"
        height="{{ block.settings.hero_image.height }}"
        class="ai-parallax-hero__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-parallax-hero__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-parallax-hero__empty-state-{{ ai_gen_id }}">
          Add a hero image to get started
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-parallax-hero__content-{{ ai_gen_id }}" data-parallax-text>
    {% if block.settings.heading != blank %}
      <h1 class="ai-parallax-hero__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h1>
    {% endif %}
  </div>
</parallax-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class ParallaxHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.imageWrapper = this.querySelector('[data-parallax-image]');
        this.textContent = this.querySelector('[data-parallax-text]');
        this.parallaxSpeed = parseFloat(this.dataset.parallaxSpeed) || 0.5;
        this.textSpeed = this.parallaxSpeed * 0.3;
        this.boundHandleScroll = this.handleScroll.bind(this);
      }

      connectedCallback() {
        window.addEventListener('scroll', this.boundHandleScroll, { passive: true });
        this.handleScroll();
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.boundHandleScroll);
      }

      handleScroll() {
        const rect = this.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        
        if (rect.top < windowHeight && rect.bottom > 0) {
          const scrolled = window.pageYOffset;
          const elementTop = this.offsetTop;
          const distance = scrolled - elementTop;
          
          if (this.imageWrapper) {
            const imageOffset = distance * this.parallaxSpeed;
            this.imageWrapper.style.transform = `translate3d(0, ${imageOffset}px, 0)`;
          }
          
          if (this.textContent) {
            const textOffset = distance * this.textSpeed;
            this.textContent.style.transform = `translate3d(0, ${-textOffset}px, 0)`;
          }
        }
      }
    }

    customElements.define('parallax-hero-{{ ai_gen_id }}', ParallaxHero{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Parallax hero",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Hero height",
      "default": 70
    },
    {
      "type": "range",
      "id": "parallax_speed",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Parallax speed",
      "default": 0.5
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "Discover Our Story"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 60
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "900",
          "label": "Extra bold"
        }
      ],
      "default": "900"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_padding_bottom",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "%",
      "label": "Heading position from bottom",
      "default": 20
    },
    {
      "type": "header",
      "content": "Text shadow"
    },
    {
      "type": "range",
      "id": "text_shadow_horizontal",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Horizontal offset",
      "default": 0
    },
    {
      "type": "range",
      "id": "text_shadow_vertical",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Vertical offset",
      "default": 2
    },
    {
      "type": "range",
      "id": "text_shadow_blur",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Blur",
      "default": 4
    },
    {
      "type": "range",
      "id": "text_shadow_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Shadow opacity",
      "default": 0.5
    }
  ],
  "presets": [
    {
      "name": "Parallax hero"
    }
  ]
}
{% endschema %}
